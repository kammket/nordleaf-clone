  .price-cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin: 1.5rem 0; }
  .pc { background: #f8faf9; border: 1px solid #e8ede9; border-radius: 12px; padding: 1.25rem; text-align: center; }
  .pc strong { display: block; color: #1a472a; margin-bottom: 0.3rem; font-size: 0.9rem; }
