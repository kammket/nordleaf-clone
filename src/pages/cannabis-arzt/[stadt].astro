  .article-content li { margin-bottom: 0.4rem; }
  .article-content a { color: #4caf50; }

  .steps-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; margin: 1.5rem 0; }
  .step-card { background: #f8faf9; border: 1px solid #e8ede9; border-radius: 12px; padding: 1.25rem; text-align: center; }
