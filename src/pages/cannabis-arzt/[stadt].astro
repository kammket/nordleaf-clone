const { city } = Astro.props;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'MedicalWebPage',
  name: city.metaTitle,
  description: city.metaDesc,
  about: {
    '@type': 'MedicalCondition',
    name: `Medizinisches Cannabis ${city.name}`,
  },
  publisher: { '@type': 'Organization', name: 'Grunapotheke GmbH', url: 'https://grunapotheke.de' },
};
