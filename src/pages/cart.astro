---
import Layout from '../layouts/Layout.astro';
const siteUrl = 'https://nordleaf.de';
---
<Layout
  title="Warenkorb – Nordleaf"
  description="Sehen und verwalten Sie Ihren Warenkorb bei Nordleaf. Medizinisches Cannabis bequem online bestellen."
  canonical={`${siteUrl}/cart`}
>
  <section class="cart-page">
    <div class="container">
      <nav class="breadcrumb">
        <a href="/">Startseite</a>
        <span>/</span>
        <a href="/products">Live-Bestand</a>
        <span>/</span>
        <span>Warenkorb</span>
      </nav>

      <h1 class="page-title">Dein Warenkorb</h1>

      <!-- Empty State -->
      <div id="empty-state" class="empty-state">
        <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1.5">
          <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
          <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
        </svg>
        <h2>Dein Warenkorb ist leer</h2>
        <p>Entdecke unseren Live-Bestand mit über 180 medizinischen Cannabis-Produkten.</p>
        <a href="/products" class="btn-primary">Produkte entdecken</a>
      </div>

      <!-- Cart Content (hidden by default, shown via JS) -->
      <div id="cart-content" class="cart-layout" style="display:none;">
        <div class="cart-items-col">
          <div class="cart-header-row">
            <span class="col-product">Produkt</span>
            <span class="col-price">Preis</span>
            <span class="col-qty">Menge</span>
            <span class="col-total">Gesamt</span>
            <span class="col-remove"></span>
          </div>
          <div id="cart-items-list"></div>
          <div class="cart-actions-row">
            <a href="/products" class="btn-continue">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5"/><polyline points="12 19 5 12 12 5"/></svg>
              Weiter einkaufen
            </a>
            <button id="clear-cart-btn" class="btn-clear">Warenkorb leeren</button>
          </div>
        </div>

        <aside class="cart-summary">
          <h2>Bestellübersicht</h2>
          <div class="summary-rows">
            <div class="summary-row">
              <span>Zwischensumme</span>
              <span id="subtotal">€0,00</span>
            </div>
            <div class="summary-row">
              <span>Versand</span>
              <span id="shipping" class="shipping-free">Kostenlos</span>
            </div>
            <div class="summary-row">
              <span>MwSt. (19%)</span>
              <span id="tax">€0,00</span>
            </div>
          </div>
          <div class="summary-total">
            <span>Gesamt</span>
            <span id="total">€0,00</span>
          </div>
          <a href="/checkout" class="btn-checkout" id="checkout-btn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
            Zur Kasse
          </a>
          <div class="trust-info">
            <div class="trust-item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4caf50" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              <span>SSL-verschlüsselt & sicher</span>
            </div>
            <div class="trust-item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4caf50" stroke-width="2"><rect x="1" y="3" width="15" height="13" rx="2"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
              <span>1-3 Werktage Lieferung</span>
            </div>
            <div class="trust-item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4caf50" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              <span>100% Apothekenqualität</span>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <script>
    import { getCart, removeFromCart, updateQuantity, clearCart, calculateTotal } from '../utils/cart';

    const emptyState = document.getElementById('empty-state')!;
    const cartContent = document.getElementById('cart-content')!;
    const cartItemsList = document.getElementById('cart-items-list')!;
    const subtotalEl = document.getElementById('subtotal')!;
    const taxEl = document.getElementById('tax')!;
    const totalEl = document.getElementById('total')!;
    const clearBtn = document.getElementById('clear-cart-btn')!;

    function fmt(n: number) {
      return `€${n.toFixed(2).replace('.', ',')}`;
    }

    function renderCart() {
      const cart = getCart();

      if (cart.items.length === 0) {
        emptyState.style.display = '';
        cartContent.style.display = 'none';
        return;
      }

      emptyState.style.display = 'none';
      cartContent.style.display = '';

      let html = '';
      cart.items.forEach((item) => {
        const lineTotal = item.price * item.quantity;
        html += `
          <div class="cart-item" data-id="${item.id}">
            <div class="item-product">
              <a href="/${item.id}" class="item-image">
                <img src="${item.image}" alt="${item.name}" loading="lazy" />
              </a>
              <div class="item-info">
                <a href="/${item.id}" class="item-name">${item.name}</a>
                <span class="item-unit-price-mobile">${fmt(item.price)} / Einheit</span>
              </div>
            </div>
            <div class="item-price">${fmt(item.price)}</div>
            <div class="item-qty">
              <div class="qty-control">
                <button class="qty-btn qty-minus" data-id="${item.id}" aria-label="Menge verringern">−</button>
                <input type="number" class="qty-input" data-id="${item.id}" value="${item.quantity}" min="1" max="99" aria-label="Menge" />
                <button class="qty-btn qty-plus" data-id="${item.id}" aria-label="Menge erhöhen">+</button>
              </div>
            </div>
            <div class="item-total">${fmt(lineTotal)}</div>
            <button class="item-remove" data-id="${item.id}" aria-label="Entfernen">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
            </button>
          </div>
        `;
      });
      cartItemsList.innerHTML = html;

      // Update summary
      const subtotal = calculateTotal(cart.items);
      const tax = parseFloat((subtotal * 0.19).toFixed(2));
      const total = parseFloat((subtotal + tax).toFixed(2));
      subtotalEl.textContent = fmt(subtotal);
      taxEl.textContent = fmt(tax);
      totalEl.textContent = fmt(total);

      // Attach event listeners
      cartItemsList.querySelectorAll('.qty-minus').forEach(btn => {
        btn.addEventListener('click', () => {
          const id = (btn as HTMLElement).dataset.id!;
          const input = cartItemsList.querySelector(`.qty-input[data-id="${id}"]`) as HTMLInputElement;
          const newQty = Math.max(1, parseInt(input.value) - 1);
          updateQuantity(id, newQty);
          renderCart();
        });
      });

      cartItemsList.querySelectorAll('.qty-plus').forEach(btn => {
        btn.addEventListener('click', () => {
          const id = (btn as HTMLElement).dataset.id!;
          const input = cartItemsList.querySelector(`.qty-input[data-id="${id}"]`) as HTMLInputElement;
          const newQty = Math.min(99, parseInt(input.value) + 1);
          updateQuantity(id, newQty);
          renderCart();
        });
      });

      cartItemsList.querySelectorAll('.qty-input').forEach(input => {
        input.addEventListener('change', () => {
          const el = input as HTMLInputElement;
          const id = el.dataset.id!;
          let val = parseInt(el.value);
          if (isNaN(val) || val < 1) val = 1;
          if (val > 99) val = 99;
          updateQuantity(id, val);
          renderCart();
        });
      });

      cartItemsList.querySelectorAll('.item-remove').forEach(btn => {
        btn.addEventListener('click', () => {
          const id = (btn as HTMLElement).dataset.id!;
          removeFromCart(id);
          renderCart();
          document.dispatchEvent(new Event('cart-updated'));
        });
      });
    }

    clearBtn?.addEventListener('click', () => {
      clearCart();
      renderCart();
      document.dispatchEvent(new Event('cart-updated'));
    });

    renderCart();
    window.addEventListener('cart-updated', renderCart);
  </script>
</Layout>

<style>
  .cart-page {
    padding: 2rem 1.5rem 4rem;
    min-height: 60vh;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    color: #999;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .breadcrumb a {
    color: #666;
    transition: color 0.2s;
    white-space: nowrap;
  }

  .breadcrumb a:hover {
    color: #4caf50;
  }

  .page-title {
    font-size: 2rem;
    font-weight: 800;
    color: #1a472a;
    margin-bottom: 2rem;
    letter-spacing: -0.02em;
  }

  /* Empty State */
  .empty-state {
    text-align: center;
    padding: 4rem 1rem;
  }

  .empty-state svg {
    margin-bottom: 1.5rem;
    opacity: 0.5;
  }

  .empty-state h2 {
    font-size: 1.5rem;
    font-weight: 700;
    color: #1a472a;
    margin-bottom: 0.5rem;
  }

  .empty-state p {
    color: #888;
    margin-bottom: 2rem;
    max-width: 400px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.5;
  }

  .btn-primary {
    display: inline-block;
    background: #4caf50;
    color: white;
    padding: 0.85rem 2rem;
    border-radius: 10px;
    font-weight: 700;
    font-size: 1rem;
    transition: all 0.2s;
    text-decoration: none;
  }

  .btn-primary:hover {
    background: #43a047;
    box-shadow: 0 4px 15px rgba(76, 175, 80, 0.3);
  }

  /* Cart Layout */
  .cart-layout {
    display: grid;
    grid-template-columns: 1fr 360px;
    gap: 2rem;
    align-items: start;
  }

  /* Cart Items Column */
  .cart-items-col {
    min-width: 0;
  }

  .cart-header-row {
    display: grid;
    grid-template-columns: 2.5fr 1fr 120px 1fr 40px;
    gap: 1rem;
    align-items: center;
    padding: 0.75rem 1rem;
    background: #f8faf9;
    border: 1px solid #e8ede9;
    border-radius: 10px 10px 0 0;
    font-size: 0.75rem;
    font-weight: 700;
    color: #888;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .cart-item {
    display: grid;
    grid-template-columns: 2.5fr 1fr 120px 1fr 40px;
    gap: 1rem;
    align-items: center;
    padding: 1rem;
    border: 1px solid #e8ede9;
    border-top: none;
    background: white;
    transition: background 0.15s;
  }

  .cart-item:last-child {
    border-radius: 0 0 10px 10px;
  }

  .cart-item:hover {
    background: #fcfdfb;
  }

  .item-product {
    display: flex;
    align-items: center;
    gap: 1rem;
    min-width: 0;
  }

  .item-image {
    flex-shrink: 0;
    width: 72px;
    height: 72px;
    border-radius: 10px;
    overflow: hidden;
    background: #f0f4f0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .item-image img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 4px;
  }

  .item-info {
    min-width: 0;
    flex: 1;
  }

  .item-name {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis;
    font-weight: 600;
    color: #1a472a;
    font-size: 0.92rem;
    line-height: 1.3;
    text-decoration: none;
    transition: color 0.2s;
  }

  .item-name:hover {
    color: #4caf50;
  }

  .item-unit-price-mobile {
    display: none;
    font-size: 0.8rem;
    color: #999;
    margin-top: 0.25rem;
  }

  .item-price {
    font-weight: 600;
    color: #555;
    font-size: 0.95rem;
    white-space: nowrap;
  }

  .item-total {
    font-weight: 700;
    color: #1a472a;
    font-size: 0.95rem;
    white-space: nowrap;
  }

  /* Quantity Control */
  .qty-control {
    display: inline-flex;
    align-items: center;
    border: 1px solid #ddd;
    border-radius: 8px;
    overflow: hidden;
  }

  .qty-btn {
    width: 34px;
    height: 34px;
    border: none;
    background: #f8faf9;
    color: #555;
    font-size: 1.1rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.15s;
    padding: 0;
    line-height: 1;
  }

  .qty-btn:hover {
    background: #e8f5e9;
    color: #1a472a;
  }

  .qty-input {
    width: 42px;
    height: 34px;
    text-align: center;
    border: none;
    border-left: 1px solid #ddd;
    border-right: 1px solid #ddd;
    font-size: 0.9rem;
    font-weight: 600;
    color: #333;
    -moz-appearance: textfield;
    background: white;
  }

  .qty-input::-webkit-outer-spin-button,
  .qty-input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  /* Remove Button */
  .item-remove {
    width: 36px;
    height: 36px;
    border: none;
    background: none;
    color: #bbb;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    transition: all 0.15s;
    padding: 0;
    flex-shrink: 0;
  }

  .item-remove:hover {
    background: #fde8e8;
    color: #e53935;
  }

  /* Cart Actions */
  .cart-actions-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 1.25rem;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .btn-continue {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: #1a472a;
    font-weight: 600;
    font-size: 0.9rem;
    text-decoration: none;
    padding: 0.6rem 1rem;
    border-radius: 8px;
    transition: all 0.15s;
    white-space: nowrap;
  }

  .btn-continue:hover {
    background: #f0f4f0;
    color: #4caf50;
  }

  .btn-clear {
    border: none;
    background: none;
    color: #bbb;
    font-size: 0.85rem;
    cursor: pointer;
    padding: 0.6rem 1rem;
    border-radius: 8px;
    transition: all 0.15s;
    white-space: nowrap;
  }

  .btn-clear:hover {
    background: #fde8e8;
    color: #e53935;
  }

  /* Cart Summary Sidebar */
  .cart-summary {
    position: sticky;
    top: 2rem;
    background: #f8faf9;
    border: 1px solid #e8ede9;
    border-radius: 14px;
    padding: 1.75rem;
  }

  .cart-summary h2 {
    font-size: 1.15rem;
    font-weight: 700;
    color: #1a472a;
    margin-bottom: 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid #e8ede9;
  }

  .summary-rows {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .summary-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.92rem;
    color: #666;
  }

  .summary-row span:last-child {
    font-weight: 600;
    color: #333;
  }

  .shipping-free {
    color: #4caf50 !important;
    font-weight: 600;
  }

  .summary-total {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 1rem;
    border-top: 2px solid #1a472a;
    margin-bottom: 1.5rem;
  }

  .summary-total span:first-child {
    font-size: 1rem;
    font-weight: 700;
    color: #1a472a;
  }

  .summary-total span:last-child {
    font-size: 1.35rem;
    font-weight: 800;
    color: #1a472a;
  }

  .btn-checkout {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    padding: 1rem;
    background: #4caf50;
    color: white;
    text-align: center;
    border-radius: 10px;
    font-weight: 700;
    font-size: 1.05rem;
    text-decoration: none;
    transition: all 0.2s;
    letter-spacing: 0.01em;
    box-sizing: border-box;
  }

  .btn-checkout:hover {
    background: #43a047;
    box-shadow: 0 4px 15px rgba(76, 175, 80, 0.3);
    transform: translateY(-1px);
  }

  /* Trust Info */
  .trust-info {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    margin-top: 1.5rem;
    padding-top: 1.25rem;
    border-top: 1px solid #e8ede9;
  }

  .trust-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    color: #777;
  }

  .trust-item svg {
    flex-shrink: 0;
  }

  /* ===== Responsive ===== */

  /* Tablet: stack to single column */
  @media (max-width: 960px) {
    .cart-layout {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .cart-summary {
      position: static;
      max-width: 100%;
    }
  }

  /* Mobile: card-style items */
  @media (max-width: 768px) {
    .cart-page {
      padding: 1.25rem 1rem 3rem;
    }

    .page-title {
      font-size: 1.5rem;
      margin-bottom: 1.25rem;
    }

    .cart-header-row {
      display: none;
    }

    .cart-item {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0;
      padding: 1rem;
      border: 1px solid #e8ede9;
      border-top: none;
      border-radius: 0;
      position: relative;
    }

    .cart-item:first-child {
      border-top: 1px solid #e8ede9;
      border-radius: 10px 10px 0 0;
    }

    .cart-item:last-child {
      border-radius: 0 0 10px 10px;
    }

    /* Row 1: image + name + remove */
    .item-product {
      width: 100%;
      padding-right: 2.5rem;
      margin-bottom: 0.75rem;
    }

    .item-image {
      width: 60px;
      height: 60px;
    }

    .item-name {
      font-size: 0.88rem;
    }

    .item-unit-price-mobile {
      display: block;
    }

    .item-price {
      display: none;
    }

    .item-remove {
      position: absolute;
      top: 1rem;
      right: 0.75rem;
      width: 32px;
      height: 32px;
    }

    /* Row 2: qty left, total right */
    .item-qty {
      flex: 1;
    }

    .item-total {
      flex-shrink: 0;
      font-size: 1rem;
      text-align: right;
    }

    /* Actions */
    .cart-actions-row {
      flex-direction: column;
      align-items: stretch;
      gap: 0.5rem;
      margin-top: 1rem;
    }

    .btn-continue {
      justify-content: center;
      padding: 0.75rem;
      background: #f8faf9;
      border: 1px solid #e8ede9;
      border-radius: 10px;
      font-size: 0.88rem;
    }

    .btn-clear {
      text-align: center;
      padding: 0.65rem;
      font-size: 0.82rem;
    }

    /* Summary */
    .cart-summary {
      padding: 1.25rem;
      border-radius: 12px;
    }

    .cart-summary h2 {
      font-size: 1.05rem;
      margin-bottom: 1rem;
      padding-bottom: 0.6rem;
    }

    .btn-checkout {
      padding: 0.9rem;
      font-size: 1rem;
    }

    /* Trust badges row on mobile */
    .trust-info {
      flex-direction: row;
      flex-wrap: wrap;
      gap: 0.5rem 1rem;
    }

    .trust-item {
      font-size: 0.75rem;
    }
  }

  /* Small phones */
  @media (max-width: 400px) {
    .page-title {
      font-size: 1.3rem;
    }

    .item-image {
      width: 52px;
      height: 52px;
    }

    .item-name {
      font-size: 0.82rem;
    }

    .qty-btn {
      width: 30px;
      height: 30px;
      font-size: 1rem;
    }

    .qty-input {
      width: 36px;
      height: 30px;
      font-size: 0.82rem;
    }

    .item-total {
      font-size: 0.92rem;
    }

    .empty-state {
      padding: 2.5rem 0.5rem;
    }

    .empty-state h2 {
      font-size: 1.2rem;
    }

    .empty-state p {
      font-size: 0.9rem;
    }

    .btn-primary {
      width: 100%;
      text-align: center;
      padding: 0.75rem 1.5rem;
      font-size: 0.95rem;
    }
  }
</style>
