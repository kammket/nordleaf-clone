---
import Layout from '../layouts/Layout.astro';
const siteUrl = 'https://grunapotheke.de';
---
<Layout
  title="Warenkorb – Grunapotheke"
  description="Sehen und verwalten Sie Ihren Warenkorb bei Grunapotheke. Medizinisches Cannabis bequem online bestellen."
  canonical={`${siteUrl}/cart`}
  noindex={true}
>
  <section class="cart-page">
    <div class="container">
      <nav class="breadcrumb">
        <a href="/">Startseite</a>
        <span>/</span>
        <a href="/products">Live-Bestand</a>
        <span>/</span>
        <span>Warenkorb</span>
      </nav>

      <div class="cart-page-header">
        <h1 class="page-title">Dein Warenkorb</h1>
        <span id="item-count-badge" class="item-count-badge" style="display:none;">0 Artikel</span>
      </div>

      <!-- Empty State -->
      <div id="empty-state" class="empty-state">
        <div class="empty-icon">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#b8c9ba" stroke-width="1.5">
            <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
            <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
          </svg>
        </div>
        <h2>Dein Warenkorb ist leer</h2>
        <p>Entdecke unseren Live-Bestand mit über 180 medizinischen Cannabis-Produkten.</p>
        <a href="/products" class="btn-primary">Produkte entdecken</a>
      </div>

      <!-- Cart Content -->
      <div id="cart-content" class="cart-layout" style="display:none;">
        <div class="cart-items-col">
          <div id="cart-items-list" class="cart-items-list"></div>
          <div class="cart-actions-row">
            <a href="/products" class="btn-continue">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5"/><polyline points="12 19 5 12 12 5"/></svg>
              Weiter einkaufen
            </a>
            <button id="clear-cart-btn" class="btn-clear">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
              Warenkorb leeren
            </button>
          </div>
        </div>

        <aside class="cart-summary">
          <h2>Bestellübersicht</h2>
          <div class="summary-rows">
            <div class="summary-row">
              <span>Zwischensumme</span>
              <span id="subtotal">€0,00</span>
            </div>
            <div class="summary-row">
              <span>Versand</span>
              <span id="shipping" class="shipping-free">Kostenlos</span>
            </div>
            <div class="summary-row">
              <span>MwSt. (19%)</span>
              <span id="tax">€0,00</span>
            </div>
          </div>
          <div class="summary-total">
            <span>Gesamt</span>
            <span id="total">€0,00</span>
          </div>

          <a href="/checkout" class="btn-checkout" id="checkout-btn">
            Zur Kasse
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>

          <div id="min-order-notice" class="notice notice--warn" style="display:none;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            <span>Mindestbestellwert: <strong>€100,00</strong>. Bitte füge weitere Produkte hinzu.</span>
          </div>
          <div id="btc-only-notice" class="notice notice--info" style="display:none;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
            <span>Bestellungen unter €200 sind nur per <strong>Bitcoin</strong> zahlbar.</span>
          </div>

          <div class="trust-badges">
            <div class="trust-badge">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#4caf50" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              <span>SSL-verschlüsselt</span>
            </div>
            <div class="trust-badge">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#4caf50" stroke-width="2"><rect x="1" y="3" width="15" height="13" rx="2"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
              <span>1-3 Werktage</span>
            </div>
            <div class="trust-badge">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#4caf50" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              <span>Apothekenqualität</span>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <script>
    import { getCart, removeFromCart, updateQuantity, clearCart, calculateTotal } from '../utils/cart';
    import { products } from '../utils/products';

    const emptyState = document.getElementById('empty-state')!;
    const cartContent = document.getElementById('cart-content')!;
    const cartItemsList = document.getElementById('cart-items-list')!;
    const subtotalEl = document.getElementById('subtotal')!;
    const taxEl = document.getElementById('tax')!;
    const totalEl = document.getElementById('total')!;
    const clearBtn = document.getElementById('clear-cart-btn')!;
    const checkoutBtn = document.getElementById('checkout-btn') as HTMLAnchorElement;
    const minOrderNotice = document.getElementById('min-order-notice')!;
    const btcOnlyNotice = document.getElementById('btc-only-notice')!;
    const itemCountBadge = document.getElementById('item-count-badge')!;

    function fmt(n: number) {
      return `€${n.toFixed(2).replace('.', ',')}`;
    }

    function blockCheckout(e: Event) {
      e.preventDefault();
    }

    /** Look up full product details by cart item id (slug) */
    function findProduct(id: string) {
      return products.find(p => p.slug === id) || null;
    }

    function renderCart() {
      const cart = getCart();

      if (cart.items.length === 0) {
        emptyState.style.display = '';
        cartContent.style.display = 'none';
        itemCountBadge.style.display = 'none';
        return;
      }

      emptyState.style.display = 'none';
      cartContent.style.display = '';

      const totalItems = cart.items.reduce((s, i) => s + i.quantity, 0);
      itemCountBadge.textContent = `${totalItems} Artikel`;
      itemCountBadge.style.display = '';

      let html = '';
      cart.items.forEach((item) => {
        const lineTotal = item.price * item.quantity;
        const prod = findProduct(item.id);
        const brand = prod?.brand || '';
        const thc = prod?.thc || '';
        const cbd = prod?.cbd || '';
        const category = prod?.category || '';
        const strain = prod?.strain || '';
        const priceUnit = prod?.priceUnit || 'Stück';
        const origin = prod?.origin || '';

        // Category tag color
        const catColors: Record<string, string> = {
          'Cannabisblüten': '#e8f5e9;color:#2e7d32',
          'Cannabisextrakte': '#e3f2fd;color:#1565c0',
          'THC Vapes': '#f3e5f5;color:#7b1fa2',
          'THC Shots': '#fff3e0;color:#e65100',
          'Kapseln & Edibles': '#fce4ec;color:#c62828',
        };
        const catStyle = catColors[category] || '#f5f5f5;color:#555';

        html += `
          <div class="cart-card" data-id="${item.id}">
            <a href="/${item.id}" class="cart-card__image">
              <img src="${item.image}" alt="${item.name}" width="120" height="120" loading="lazy" />
            </a>
            <div class="cart-card__body">
              <div class="cart-card__details">
                <div class="cart-card__top">
                  ${category ? `<span class="cart-card__cat" style="background:${catStyle}">${category}</span>` : ''}
                  ${brand ? `<span class="cart-card__brand">${brand}</span>` : ''}
                </div>
                <a href="/${item.id}" class="cart-card__name">${strain || item.name}</a>
                <div class="cart-card__meta">
                  ${thc ? `<span class="meta-pill meta-pill--thc">THC ${thc}</span>` : ''}
                  ${cbd && cbd !== '0%' && cbd !== '0,0%' ? `<span class="meta-pill meta-pill--cbd">CBD ${cbd}</span>` : ''}
                  ${origin ? `<span class="meta-pill meta-pill--origin">${origin}</span>` : ''}
                </div>
                <div class="cart-card__unit-price">${fmt(item.price)} / ${priceUnit}</div>
              </div>
              <div class="cart-card__controls">
                <div class="cart-card__qty">
                  <button class="qty-btn qty-minus" data-id="${item.id}" aria-label="Menge verringern">−</button>
                  <input type="number" class="qty-input" data-id="${item.id}" value="${item.quantity}" min="1" max="99" aria-label="Menge" />
                  <button class="qty-btn qty-plus" data-id="${item.id}" aria-label="Menge erhöhen">+</button>
                </div>
                <div class="cart-card__line-total">${fmt(lineTotal)}</div>
              </div>
            </div>
            <button class="cart-card__remove" data-id="${item.id}" aria-label="Produkt entfernen" title="Entfernen">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
          </div>
        `;
      });
      cartItemsList.innerHTML = html;

      // Update summary
      const subtotal = calculateTotal(cart.items);
      const tax = parseFloat((subtotal * 0.19).toFixed(2));
      const total = parseFloat((subtotal + tax).toFixed(2));
      subtotalEl.textContent = fmt(subtotal);
      taxEl.textContent = fmt(tax);
      totalEl.textContent = fmt(total);

      // Minimum order enforcement
      if (total < 100) {
        checkoutBtn.classList.add('disabled');
        checkoutBtn.addEventListener('click', blockCheckout);
        minOrderNotice.style.display = 'flex';
        btcOnlyNotice.style.display = 'none';
      } else {
        checkoutBtn.classList.remove('disabled');
        checkoutBtn.removeEventListener('click', blockCheckout);
        minOrderNotice.style.display = 'none';
        btcOnlyNotice.style.display = total < 200 ? 'flex' : 'none';
      }

      // Attach event listeners
      cartItemsList.querySelectorAll('.qty-minus').forEach(btn => {
        btn.addEventListener('click', () => {
          const id = (btn as HTMLElement).dataset.id!;
          const input = cartItemsList.querySelector(`.qty-input[data-id="${id}"]`) as HTMLInputElement;
          const newQty = Math.max(1, parseInt(input.value) - 1);
          updateQuantity(id, newQty);
          renderCart();
        });
      });

      cartItemsList.querySelectorAll('.qty-plus').forEach(btn => {
        btn.addEventListener('click', () => {
          const id = (btn as HTMLElement).dataset.id!;
          const input = cartItemsList.querySelector(`.qty-input[data-id="${id}"]`) as HTMLInputElement;
          const newQty = Math.min(99, parseInt(input.value) + 1);
          updateQuantity(id, newQty);
          renderCart();
        });
      });

      cartItemsList.querySelectorAll('.qty-input').forEach(input => {
        input.addEventListener('change', () => {
          const el = input as HTMLInputElement;
          const id = el.dataset.id!;
          let val = parseInt(el.value);
          if (isNaN(val) || val < 1) val = 1;
          if (val > 99) val = 99;
          updateQuantity(id, val);
          renderCart();
        });
      });

      cartItemsList.querySelectorAll('.cart-card__remove').forEach(btn => {
        btn.addEventListener('click', () => {
          const id = (btn as HTMLElement).dataset.id!;
          // Animate out
          const card = btn.closest('.cart-card') as HTMLElement;
          if (card) {
            card.style.transition = 'opacity 0.25s, transform 0.25s';
            card.style.opacity = '0';
            card.style.transform = 'translateX(30px)';
            setTimeout(() => {
              removeFromCart(id);
              renderCart();
              document.dispatchEvent(new Event('cart-updated'));
            }, 250);
          } else {
            removeFromCart(id);
            renderCart();
            document.dispatchEvent(new Event('cart-updated'));
          }
        });
      });
    }

    clearBtn?.addEventListener('click', () => {
      clearCart();
      renderCart();
      document.dispatchEvent(new Event('cart-updated'));
    });

    renderCart();
    window.addEventListener('cart-updated', renderCart);
  </script>
</Layout>

<style>
  /* ===== Page Shell ===== */
  .cart-page {
    padding: 2rem 1.5rem 4rem;
    min-height: 60vh;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    color: #999;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }
  .breadcrumb a { color: #666; transition: color 0.2s; white-space: nowrap; text-decoration: none; }
  .breadcrumb a:hover { color: #4caf50; }

  .cart-page-header {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }

  .page-title {
    font-size: 2rem;
    font-weight: 800;
    color: #1a472a;
    letter-spacing: -0.02em;
    margin: 0;
  }

  .item-count-badge {
    background: #e8f5e9;
    color: #2e7d32;
    font-size: 0.8rem;
    font-weight: 600;
    padding: 0.25rem 0.75rem;
    border-radius: 20px;
    white-space: nowrap;
  }

  /* ===== Empty State ===== */
  .empty-state {
    text-align: center;
    padding: 4rem 1rem;
  }
  .empty-icon {
    width: 80px; height: 80px;
    margin: 0 auto 1.5rem;
    background: #f0f4f0;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
  }
  .empty-state h2 { font-size: 1.4rem; font-weight: 700; color: #1a472a; margin-bottom: 0.5rem; }
  .empty-state p { color: #888; margin-bottom: 2rem; max-width: 400px; margin-left: auto; margin-right: auto; line-height: 1.5; }
  .btn-primary {
    display: inline-block; background: #4caf50; color: white;
    padding: 0.85rem 2rem; border-radius: 10px; font-weight: 700;
    font-size: 1rem; transition: all 0.2s; text-decoration: none;
  }
  .btn-primary:hover { background: #43a047; box-shadow: 0 4px 15px rgba(76,175,80,0.3); }

  /* ===== Cart Layout (2-col) ===== */
  .cart-layout {
    display: grid;
    grid-template-columns: 1fr 360px;
    gap: 2rem;
    align-items: start;
  }

  .cart-items-col { min-width: 0; }

  /* ===== Cart Card (each product) ===== */
  .cart-items-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .cart-card {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1.25rem;
    background: white;
    border: 1px solid #e8ede9;
    border-radius: 14px;
    position: relative;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .cart-card:hover {
    border-color: #c8d8ca;
    box-shadow: 0 2px 12px rgba(26,71,42,0.05);
  }

  /* Product Image */
  .cart-card__image {
    flex-shrink: 0;
    width: 100px; height: 100px;
    border-radius: 12px;
    overflow: hidden;
    background: #f5f8f5;
    display: flex; align-items: center; justify-content: center;
  }
  .cart-card__image img {
    width: 100%; height: 100%;
    object-fit: contain;
    padding: 6px;
    transition: transform 0.2s;
  }
  .cart-card__image:hover img { transform: scale(1.05); }

  /* Card Body */
  .cart-card__body {
    flex: 1;
    min-width: 0;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
  }

  .cart-card__details {
    flex: 1;
    min-width: 0;
  }

  .cart-card__top {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.35rem;
    flex-wrap: wrap;
  }

  .cart-card__cat {
    font-size: 0.68rem;
    font-weight: 700;
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    white-space: nowrap;
  }

  .cart-card__brand {
    font-size: 0.78rem;
    color: #888;
    font-weight: 500;
  }

  .cart-card__name {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis;
    font-weight: 700;
    color: #1a472a;
    font-size: 0.95rem;
    line-height: 1.35;
    text-decoration: none;
    transition: color 0.2s;
    margin-bottom: 0.4rem;
  }
  .cart-card__name:hover { color: #4caf50; }

  .cart-card__meta {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    flex-wrap: wrap;
    margin-bottom: 0.35rem;
  }

  .meta-pill {
    font-size: 0.7rem;
    font-weight: 600;
    padding: 0.15rem 0.45rem;
    border-radius: 4px;
    white-space: nowrap;
  }
  .meta-pill--thc { background: #e8f5e9; color: #2e7d32; }
  .meta-pill--cbd { background: #e3f2fd; color: #1565c0; }
  .meta-pill--origin { background: #f5f5f5; color: #666; }

  .cart-card__unit-price {
    font-size: 0.82rem;
    color: #999;
  }

  /* Controls column (qty + total) */
  .cart-card__controls {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.75rem;
    padding-top: 0.15rem;
  }

  /* Quantity control */
  .cart-card__qty {
    display: inline-flex;
    align-items: center;
    border: 1.5px solid #e0e5e0;
    border-radius: 10px;
    overflow: hidden;
    background: #f8faf9;
  }

  .qty-btn {
    width: 36px; height: 36px;
    border: none;
    background: transparent;
    color: #555;
    font-size: 1.15rem;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: all 0.15s;
    padding: 0; line-height: 1;
  }
  .qty-btn:hover { background: #e8f5e9; color: #1a472a; }
  .qty-btn:active { background: #c8e6c9; }

  .qty-input {
    width: 40px; height: 36px;
    text-align: center;
    border: none;
    border-left: 1.5px solid #e0e5e0;
    border-right: 1.5px solid #e0e5e0;
    font-size: 0.9rem;
    font-weight: 700;
    color: #1a472a;
    -moz-appearance: textfield;
    background: white;
  }
  .qty-input::-webkit-outer-spin-button,
  .qty-input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
  .qty-input:focus { outline: none; background: #f0fff0; }

  /* Line total */
  .cart-card__line-total {
    font-size: 1.1rem;
    font-weight: 800;
    color: #1a472a;
    white-space: nowrap;
  }

  /* Remove button */
  .cart-card__remove {
    position: absolute;
    top: 0.75rem; right: 0.75rem;
    width: 28px; height: 28px;
    border: none; background: none;
    color: #ccc;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    border-radius: 6px;
    transition: all 0.15s;
    padding: 0;
  }
  .cart-card__remove:hover { background: #fde8e8; color: #e53935; }

  /* ===== Cart Actions Row ===== */
  .cart-actions-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 1.25rem;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .btn-continue {
    display: inline-flex; align-items: center;
    gap: 0.4rem; color: #1a472a;
    font-weight: 600; font-size: 0.9rem;
    text-decoration: none; padding: 0.6rem 1rem;
    border-radius: 8px; transition: all 0.15s;
    white-space: nowrap;
  }
  .btn-continue:hover { background: #f0f4f0; color: #4caf50; }

  .btn-clear {
    display: inline-flex; align-items: center;
    gap: 0.35rem;
    border: none; background: none;
    color: #bbb; font-size: 0.85rem;
    cursor: pointer; padding: 0.6rem 1rem;
    border-radius: 8px; transition: all 0.15s;
    white-space: nowrap;
  }
  .btn-clear:hover { background: #fde8e8; color: #e53935; }

  /* ===== Summary Sidebar ===== */
  .cart-summary {
    position: sticky;
    top: 2rem;
    background: #f8faf9;
    border: 1px solid #e8ede9;
    border-radius: 16px;
    padding: 1.75rem;
  }

  .cart-summary h2 {
    font-size: 1.1rem;
    font-weight: 700;
    color: #1a472a;
    margin-bottom: 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid #e8ede9;
  }

  .summary-rows {
    display: flex; flex-direction: column;
    gap: 0.75rem; margin-bottom: 1rem;
  }
  .summary-row {
    display: flex; justify-content: space-between;
    align-items: center;
    font-size: 0.92rem; color: #666;
  }
  .summary-row span:last-child { font-weight: 600; color: #333; }
  .shipping-free { color: #4caf50 !important; }

  .summary-total {
    display: flex; justify-content: space-between;
    align-items: center;
    padding-top: 1rem;
    border-top: 2px solid #1a472a;
    margin-bottom: 1.5rem;
  }
  .summary-total span:first-child { font-size: 1rem; font-weight: 700; color: #1a472a; }
  .summary-total span:last-child { font-size: 1.35rem; font-weight: 800; color: #1a472a; }

  /* Checkout button */
  .btn-checkout {
    display: flex; align-items: center; justify-content: center;
    gap: 0.5rem; width: 100%;
    padding: 1rem; background: #1a472a;
    color: white; text-align: center;
    border-radius: 12px; font-weight: 700;
    font-size: 1.05rem; text-decoration: none;
    transition: all 0.2s; box-sizing: border-box;
  }
  .btn-checkout:hover { background: #2d6a47; box-shadow: 0 4px 20px rgba(26,71,42,0.25); transform: translateY(-1px); }
