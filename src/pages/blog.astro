---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
---

<Layout
  title="Blog — Cannabis Ratgeber & Wissen | Grunapotheke"
  description="Aktuelle Artikel über medizinisches Cannabis, Therapien, Sorten und Neuigkeiten aus der Cannabis-Medizin."
  keywords="Cannabis Blog, medizinisches Cannabis Artikel, Cannabis Wissen, Cannabis Therapie"
  canonical="https://grunapotheke.de/ratgeber"
  noindex={true}
>
  <Breadcrumb items={[{name: "Blog", url: "/ratgeber"}]} />

  <!-- Meta refresh redirect to /ratgeber -->
  <meta http-equiv="refresh" content="0;url=/ratgeber" />

  <section class="page-hero">
    <div class="container">
      <h1>Blog</h1>
      <p>Du wirst weitergeleitet zum <a href="/ratgeber" style="color:#4caf50;font-weight:700;">Grunapotheke Ratgeber</a>.</p>
    </div>
  </section>
</Layout>

<style>
  .page-hero {
    background: linear-gradient(135deg, #0d2618, #1a472a, #2d6a47);
    color: white; padding: 3.5rem 1.5rem; text-align: center;
    min-height: 40vh; display: flex; align-items: center; justify-content: center;
  }
  .page-hero h1 { font-size: 2.5rem; font-weight: 800; margin-bottom: 0.75rem; }
  .page-hero p { color: rgba(255,255,255,0.7); font-size: 1.1rem; }
</style>
