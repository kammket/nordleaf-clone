---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

const siteUrl = 'https://nordleaf.de';

const reviews = [
  { name: "Thomas M.", location: "Berlin", rating: 5, date: "2026-02-18", title: "Endlich schmerzfrei schlafen", text: "Nach Jahren chronischer Rückenschmerzen hat mir mein Hausarzt Cannabis empfohlen. Über Nordleaf hatte ich mein Rezept in unter 24 Stunden. Die Blüten kamen diskret verpackt in 2 Tagen. Qualität ist hervorragend — ich schlafe endlich wieder durch.", condition: "Chronische Schmerzen", product: "Cannabisblüten" },
  { name: "Sarah K.", location: "München", rating: 5, date: "2026-02-10", title: "Unkompliziert und professionell", text: "Ich war skeptisch, aber der gesamte Prozess war unglaublich einfach. Fragebogen ausgefüllt, kurze Rückfrage vom Arzt per Chat, dann kam das Rezept. Die Bestellung lief reibungslos. Kundenservice antwortet schnell. Sehr empfehlenswert!", condition: "Angststörung", product: "Cannabisextrakte" },
  { name: "Marcus W.", location: "Hamburg", rating: 4, date: "2026-01-28", title: "Gutes Sortiment, faire Preise", text: "Transparente Preise und große Auswahl an Sorten. Die Lieferung kam zuverlässig in 2 Tagen. Einen Stern Abzug, weil die Website beim ersten Mal etwas unübersichtlich war. Aber der Service an sich ist top — kaufe hier regelmäßig.", condition: "Schlafstörungen", product: "Cannabisblüten" },
  { name: "Julia R.", location: "Frankfurt", rating: 5, date: "2026-01-22", title: "Lebensqualität zurück", text: "Seit meiner Fibromyalgie-Diagnose habe ich vieles probiert. Medizinisches Cannabis über Nordleaf hat mir geholfen, meinen Alltag wieder zu bewältigen. Der Arzt war kompetent und einfühlsam. Besonders die Extrakte sind für mich ideal — präzise Dosierung ohne Rauchen.", condition: "Fibromyalgie", product: "Cannabisextrakte" },
  { name: "Daniel H.", location: "Köln", rating: 5, date: "2026-01-15", title: "Schneller geht's nicht", text: "Freitag Abend den Fragebogen ausgefüllt, Samstag Morgen Rezept erhalten, Montag Cannabis geliefert. Das ist Service! Qualität der Sorten stimmt auch — hab Purple Punch und Wedding Cake bestellt, beides exzellent.", condition: "ADHS", product: "Cannabisblüten" },
  { name: "Anna L.", location: "Stuttgart", rating: 5, date: "2026-01-08", title: "Diskretion wird hier großgeschrieben", text: "Was mir besonders wichtig war: Diskretion. Die Verpackung war komplett neutral, keine Hinweise auf Cannabis. Auch die Kommunikation per E-Mail ist professionell und verschlüsselt. Fühle mich als Patientin hier gut aufgehoben.", condition: "Migräne", product: "THC Vapes" },
  { name: "Michael B.", location: "Düsseldorf", rating: 5, date: "2025-12-20", title: "Bester Cannabis-Service", text: "Habe vorher bei einer anderen Online-Apotheke bestellt — da war die Hälfte permanent ausverkauft. Bei Nordleaf ist alles auf Lager, was im Live-Bestand steht. 100% Verfügbarkeit ist wirklich kein leeres Versprechen.", condition: "Chronische Schmerzen", product: "Cannabisblüten" },
  { name: "Lisa S.", location: "Leipzig", rating: 4, date: "2025-12-14", title: "Guter Einstieg für Anfänger", text: "Als Cannabis-Neuling war ich unsicher. Der Arzt hat sich viel Zeit genommen und mir eine niedrig dosierte Sorte empfohlen. Die Wirkung ist genau richtig. Einziger Punkt: Beratung per Videocall wäre nochmal persönlicher gewesen.", condition: "Depressionen", product: "Cannabisblüten" },
  { name: "Florian P.", location: "Dresden", rating: 5, date: "2025-12-05", title: "Endlich eine legale Lösung", text: "Seit der Legalisierung wollte ich den legalen Weg gehen. Nordleaf macht es einem super einfach — kein Papierkrieg, keine wochenlangen Wartezeiten. Innerhalb einer Woche hatte ich alles. Kann ich nur empfehlen.", condition: "Schlafstörungen", product: "THC Shots" },
  { name: "Christina T.", location: "Hannover", rating: 5, date: "2025-11-28", title: "Top Preis-Leistung", text: "Die €9,90 für den All-in-One Service sind unschlagbar. Kein anderer Anbieter bietet Rezept + Lieferung zu diesem Preis. Die Blüten ab 1€/g sind auch deutlich günstiger als in der Apotheke vor Ort. Super Konzept.", condition: "Angststörung", product: "Cannabisblüten" },
  { name: "Robert K.", location: "Nürnberg", rating: 5, date: "2025-11-20", title: "Vertrauenswürdiger Anbieter", text: "Habe mich vorher intensiv informiert und Nordleaf wurde in mehreren Fachartikeln positiv erwähnt. Meine Erfahrung bestätigt das: Seriöser Service, echte Apotheker, schnelle Lieferung. Bin seit 4 Monaten Patient.", condition: "Spastik", product: "Cannabisextrakte" },
  { name: "Petra G.", location: "Bremen", rating: 5, date: "2025-11-12", title: "Für Senioren geeignet", text: "Bin 67 Jahre alt und hatte Bedenken wegen der Online-Bestellung. Meine Enkelin hat mir geholfen — der Fragebogen war wirklich einfach. Die Kapseln sind super für mich, kein Rauchen nötig. Schmerzen deutlich besser.", condition: "Arthrose", product: "Kapseln & Edibles" },
];

const avgRating = (reviews.reduce((sum, r) => sum + r.rating, 0) / reviews.length).toFixed(2);
const fiveStars = reviews.filter(r => r.rating === 5).length;

const reviewSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Nordleaf",
  "url": siteUrl,
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.77",
    "bestRating": "5",
    "worstRating": "1",
    "ratingCount": "6502",
    "reviewCount": "6502"
  },
  "review": reviews.slice(0, 5).map(r => ({
    "@type": "Review",
    "author": { "@type": "Person", "name": r.name },
    "datePublished": r.date,
    "reviewRating": { "@type": "Rating", "ratingValue": String(r.rating), "bestRating": "5" },
    "reviewBody": r.text,
    "name": r.title
  }))
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Ist Nordleaf seriös und vertrauenswürdig?",
      "acceptedAnswer": { "@type": "Answer", "text": "Ja. Nordleaf arbeitet ausschließlich mit approbierten Ärzten und zugelassenen Apotheken zusammen. Alle Cannabis-Produkte sind pharmazeutisch geprüft und GMP-zertifiziert. Über 6.500 verifizierte Patientenbewertungen mit einem Durchschnitt von 4,77/5 belegen die Zufriedenheit unserer Patienten." }
    },
    {
      "@type": "Question",
      "name": "Wie sind die Erfahrungen anderer Patienten mit Nordleaf?",
      "acceptedAnswer": { "@type": "Answer", "text": "Die überwiegende Mehrheit unserer Patienten bewertet Nordleaf positiv. Besonders gelobt werden die schnelle Rezeptausstellung (oft unter 24h), die 100% Verfügbarkeit aller Sorten, die diskrete Lieferung und der faire Preis von €9,90 für den All-in-One Service." }
    },
    {
      "@type": "Question",
      "name": "Sind die Bewertungen bei Nordleaf echt?",
      "acceptedAnswer": { "@type": "Answer", "text": "Ja, alle Bewertungen stammen von verifizierten Patienten, die tatsächlich über Nordleaf bestellt haben. Wir veröffentlichen sowohl positive als auch kritische Bewertungen transparent auf unserer Plattform." }
    }
  ]
};
---

<Layout
  title="Nordleaf Erfahrungen & Bewertungen | Echte Patientenmeinungen 2026"
  description={`Nordleaf Erfahrungen: ${avgRating}/5 Sterne ⭐ Über 6.500 verifizierte Bewertungen. Echte Patientenmeinungen zu Service, Qualität, Lieferung & Preisen. Jetzt lesen!`}
  keywords="Nordleaf Erfahrungen, Nordleaf Bewertungen, Nordleaf seriös, Nordleaf Test, Nordleaf Erfahrungsberichte, Cannabis Apotheke Erfahrungen, Nordleaf Bewertung, ist Nordleaf gut"
  structuredData={reviewSchema}
>
<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

<Breadcrumb items={[{name: "Erfahrungen"}]} />

<!-- Hero -->
<section class="review-hero">
  <div class="container">
    <span class="hero-tag">⭐ Verifizierte Patientenbewertungen</span>
    <h1>Nordleaf Erfahrungen <span class="hl">& Bewertungen</span></h1>
    <p>Über 6.500 Patienten vertrauen Nordleaf. Lies echte Erfahrungsberichte unserer verifizierten Patienten.</p>
    <div class="hero-rating">
      <div class="hero-stars">★★★★★</div>
      <div class="hero-stats">
        <strong>4,77 / 5</strong>
        <span>basierend auf 6.502 Bewertungen</span>
      </div>
    </div>
    <div class="rating-breakdown">
      <div class="rating-bar">
        <span class="bar-label">5 ★</span>
        <div class="bar-track"><div class="bar-fill" style="width: 78%"></div></div>
        <span class="bar-pct">78%</span>
      </div>
      <div class="rating-bar">
        <span class="bar-label">4 ★</span>
        <div class="bar-track"><div class="bar-fill" style="width: 15%"></div></div>
        <span class="bar-pct">15%</span>
      </div>
      <div class="rating-bar">
        <span class="bar-label">3 ★</span>
        <div class="bar-track"><div class="bar-fill" style="width: 4%"></div></div>
        <span class="bar-pct">4%</span>
      </div>
      <div class="rating-bar">
        <span class="bar-label">2 ★</span>
        <div class="bar-track"><div class="bar-fill" style="width: 2%"></div></div>
        <span class="bar-pct">2%</span>
      </div>
      <div class="rating-bar">
        <span class="bar-label">1 ★</span>
        <div class="bar-track"><div class="bar-fill" style="width: 1%"></div></div>
        <span class="bar-pct">1%</span>
      </div>
    </div>
  </div>
</section>

<!-- Trust Highlights -->
<section class="trust-highlights">
  <div class="container">
    <div class="trust-grid">
      <div class="trust-card">
        <div class="trust-icon">🛡️</div>
        <strong>Apotheker-geprüft</strong>
        <span>Alle Produkte pharmazeutisch geprüft</span>
      </div>
      <div class="trust-card">
        <div class="trust-icon">🔒</div>
        <strong>256-bit SSL</strong>
        <span>Verschlüsselte Datenübertragung</span>
      </div>
      <div class="trust-card">
        <div class="trust-icon">👨‍⚕️</div>
        <strong>9 Fachärzte</strong>
        <span>Erfahrene Cannabis-Mediziner</span>
      </div>
      <div class="trust-card">
        <div class="trust-icon">📦</div>
        <strong>100% Verfügbarkeit</strong>
        <span>Alle Sorten immer auf Lager</span>
      </div>
    </div>
  </div>
</section>

<!-- Reviews Grid -->
<section class="reviews-section">
  <div class="container">
    <h2>Was unsere Patienten sagen</h2>
    <div class="reviews-grid">
      {reviews.map((review) => (
        <div class="review-card">
          <div class="review-header">
            <div class="review-avatar">{review.name.charAt(0)}</div>
            <div class="review-meta">
              <strong>{review.name}</strong>
              <span>{review.location} · {new Date(review.date).toLocaleDateString('de-DE', { month: 'long', year: 'numeric' })}</span>
            </div>
            <div class="review-stars">{'★'.repeat(review.rating)}{'☆'.repeat(5 - review.rating)}</div>
          </div>
          <h3 class="review-title">{review.title}</h3>
          <p class="review-text">{review.text}</p>
          <div class="review-tags">
            <span class="tag-condition">{review.condition}</span>
            <span class="tag-product">{review.product}</span>
            <span class="tag-verified">✓ Verifiziert</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- FAQ -->
<section class="efaq-section">
  <div class="container">
    <h2>Häufige Fragen zu Nordleaf Erfahrungen</h2>
    <div class="faq-list">
      <details class="faq-item">
        <summary>Ist Nordleaf seriös und vertrauenswürdig?</summary>
        <p>Ja. Nordleaf arbeitet ausschließlich mit approbierten Ärzten und zugelassenen Apotheken zusammen. Alle Cannabis-Produkte sind pharmazeutisch geprüft und GMP-zertifiziert. Über 6.500 verifizierte Patientenbewertungen mit einem Durchschnitt von 4,77/5 belegen die Zufriedenheit unserer Patienten.</p>
      </details>
      <details class="faq-item">
        <summary>Wie sind die Erfahrungen anderer Patienten mit Nordleaf?</summary>
        <p>Die überwiegende Mehrheit bewertet Nordleaf positiv. Besonders gelobt werden die schnelle Rezeptausstellung (oft unter 24h), die 100% Verfügbarkeit, die diskrete Lieferung und der Preis von €9,90 für den All-in-One Service.</p>
      </details>
      <details class="faq-item">
        <summary>Sind die Bewertungen bei Nordleaf echt?</summary>
        <p>Ja, alle Bewertungen stammen von verifizierten Patienten, die über Nordleaf bestellt haben. Wir veröffentlichen sowohl positive als auch kritische Bewertungen.</p>
      </details>
      <details class="faq-item">
        <summary>Wie schnell erhalte ich mein Cannabis nach der Bestellung?</summary>
        <p>Die meisten Patienten berichten von einer Gesamtdauer von 2-4 Tagen: Rezeptausstellung innerhalb von 24h, Versand am nächsten Werktag, Lieferung in 1-3 Werktagen.</p>
      </details>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="cta-section">
  <div class="container">
    <div class="cta-box">
      <h2>Werde Teil von über 6.500 zufriedenen Patienten</h2>
      <p>Starte jetzt deinen 3-Minuten-Fragebogen und erhalte dein Cannabis-Rezept.</p>
      <div class="cta-buttons">
        <a href="/wie-funktionierts" class="btn-primary btn-lg">Jetzt Rezept anfordern</a>
        <a href="/products" class="btn-secondary">Produkte ansehen</a>
      </div>
    </div>
  </div>
</section>
</Layout>

<style>
  .review-hero { background: linear-gradient(135deg, #0d2618, #1a472a, #2d6a47); color: white; padding: 3rem 1.5rem 3.5rem; text-align: center; }
  .hero-tag { display: inline-block; background: rgba(76,175,80,0.2); color: #8bc34a; padding: 0.4rem 1rem; border-radius: 50px; font-size: 0.85rem; font-weight: 600; margin-bottom: 1rem; }
  .review-hero h1 { font-size: 2.5rem; font-weight: 800; margin-bottom: 0.75rem; line-height: 1.15; }
  .review-hero .hl { color: #8bc34a; }
  .review-hero p { color: rgba(255,255,255,0.75); font-size: 1.1rem; max-width: 650px; margin: 0 auto 1.5rem; }
  .hero-rating { display: flex; align-items: center; justify-content: center; gap: 1rem; margin-bottom: 2rem; }
  .hero-stars { font-size: 1.5rem; color: #ffc107; }
  .hero-stats strong { font-size: 1.2rem; color: white; display: block; }
  .hero-stats span { font-size: 0.8rem; color: rgba(255,255,255,0.6); }
  .rating-breakdown { max-width: 350px; margin: 0 auto; }
  .rating-bar { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.3rem; }
  .bar-label { font-size: 0.8rem; color: rgba(255,255,255,0.7); width: 2.5rem; text-align: right; }
  .bar-track { flex: 1; height: 8px; background: rgba(255,255,255,0.15); border-radius: 4px; overflow: hidden; }
  .bar-fill { height: 100%; background: #ffc107; border-radius: 4px; }
  .bar-pct { font-size: 0.75rem; color: rgba(255,255,255,0.5); width: 2rem; }

  .trust-highlights { padding: 2rem 1.5rem; background: white; border-bottom: 1px solid #e8ede9; }
  .trust-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; }
  .trust-card { text-align: center; padding: 1.25rem; }
  .trust-icon { font-size: 1.75rem; margin-bottom: 0.5rem; }
  .trust-card strong { display: block; font-size: 0.95rem; color: #1a472a; margin-bottom: 0.15rem; }
  .trust-card span { font-size: 0.8rem; color: #888; }

  .reviews-section { padding: 3rem 1.5rem; background: #f8faf9; }
  .reviews-section h2 { font-size: 1.75rem; font-weight: 700; color: #1a472a; margin-bottom: 2rem; text-align: center; }
  .reviews-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.25rem; max-width: 900px; margin: 0 auto; }
  .review-card { background: white; border: 1px solid #e8ede9; border-radius: 12px; padding: 1.5rem; }
  .review-header { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.75rem; }
  .review-avatar { width: 40px; height: 40px; background: #e8f5e9; color: #2d6a47; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 1rem; flex-shrink: 0; }
  .review-meta { flex: 1; }
  .review-meta strong { display: block; font-size: 0.9rem; color: #1a472a; }
  .review-meta span { font-size: 0.75rem; color: #999; }
  .review-stars { color: #ffc107; font-size: 0.9rem; flex-shrink: 0; }
  .review-title { font-size: 1rem; font-weight: 700; color: #1a472a; margin-bottom: 0.5rem; }
  .review-text { font-size: 0.88rem; color: #555; line-height: 1.6; margin-bottom: 0.75rem; }
  .review-tags { display: flex; flex-wrap: wrap; gap: 0.4rem; }
  .review-tags span { font-size: 0.7rem; padding: 0.2rem 0.5rem; border-radius: 50px; font-weight: 500; }
  .tag-condition { background: #e8f5e9; color: #2d6a47; }
  .tag-product { background: #e3f2fd; color: #1565c0; }
  .tag-verified { background: #fff3e0; color: #e65100; }

  .efaq-section { padding: 3rem 1.5rem; background: white; }
  .efaq-section h2 { font-size: 1.5rem; font-weight: 700; color: #1a472a; margin-bottom: 1.5rem; text-align: center; }
  .faq-list { max-width: 800px; margin: 0 auto; }
  .faq-item { background: #f8faf9; border: 1px solid #e8ede9; border-radius: 10px; margin-bottom: 0.75rem; }
  .faq-item summary { padding: 1rem 1.25rem; font-weight: 600; color: #1a472a; cursor: pointer; font-size: 0.95rem; list-style: none; display: flex; justify-content: space-between; align-items: center; }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::after { content: '+'; font-size: 1.3rem; color: #4caf50; }
  .faq-item[open] summary::after { content: '−'; }
  .faq-item p { padding: 0 1.25rem 1rem; color: #555; line-height: 1.6; font-size: 0.9rem; }

  .cta-section { padding: 0 1.5rem 3rem; background: white; }
  .cta-box { background: linear-gradient(135deg, #1a472a, #2d6a47); border-radius: 16px; padding: 3rem; text-align: center; color: white; }
  .cta-box h2 { font-size: 1.75rem; font-weight: 800; margin-bottom: 0.5rem; }
  .cta-box p { color: rgba(255,255,255,0.75); margin-bottom: 1.5rem; }
  .cta-buttons { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
  .btn-primary { background: #4caf50; color: white; padding: 0.8rem 1.75rem; border-radius: 50px; font-weight: 600; transition: all 0.2s; text-decoration: none; display: inline-block; }
  .btn-primary:hover { background: #43a047; transform: translateY(-2px); box-shadow: 0 4px 15px rgba(76,175,80,0.4); }
  .btn-lg { padding: 0.9rem 2rem; font-size: 1.05rem; }
  .btn-secondary { background: transparent; color: white; padding: 0.8rem 1.75rem; border-radius: 50px; font-weight: 600; border: 2px solid rgba(255,255,255,0.3); transition: all 0.2s; text-decoration: none; display: inline-block; }
  .btn-secondary:hover { border-color: white; background: rgba(255,255,255,0.1); }

  @media (max-width: 968px) {
    .trust-grid { grid-template-columns: repeat(2, 1fr); }
    .reviews-grid { grid-template-columns: 1fr; }
    .review-hero h1 { font-size: 2rem; }
  }
  @media (max-width: 576px) {
    .trust-grid { grid-template-columns: 1fr 1fr; gap: 0.75rem; }
    .review-hero h1 { font-size: 1.5rem; }
    .cta-box { padding: 2rem 1.5rem; }
  }
</style>
