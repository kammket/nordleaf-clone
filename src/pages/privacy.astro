---
// Privacy Policy Page

import Layout from '../layouts/Layout.astro';

const siteUrl = 'https://nordleaf.de';
---

<Layout
  title="Privacy Policy - Nordleaf"
  description="Read our privacy policy to understand how we collect, use, and protect your personal data."
  canonical={`${siteUrl}/privacy`}
>
  <div class="policy-page">
    <section class="page-header">
      <div class="container">
        <h1>Privacy Policy</h1>
      </div>
    </section>

    <section class="policy-content">
      <div class="container">
        <h2>Introduction</h2>
        <p>
          At Nordleaf, we are committed to protecting your privacy. This Privacy Policy explains
          how we collect, use, and protect your information.
        </p>

        <h2>Information We Collect</h2>
        <ul>
          <li>Personal Data: Name, email, address, phone number</li>
          <li>Payment Information: Credit card details (processed securely)</li>
          <li>Behavioral Data: Pages visited, clicks, interactions</li>
        </ul>

        <h2>How We Use Your Information</h2>
        <p>We use your information to process orders, improve our services, and communicate with you about your purchase.</p>

        <h2>Contact Us</h2>
        <p>Email: <a href="mailto:privacy@nordleaf.de">privacy@nordleaf.de</a></p>
      </div>
    </section>
  </div>
</Layout>

<style>
  .container {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  .page-header {
    background: linear-gradient(135deg, #1a472a 0%, #2d6a47 100%);
    color: white;
    padding: 3rem 0;
    text-align: center;
  }

  .page-header h1 {
    color: white;
  }

  .policy-content {
    padding: 3rem 0;
  }

  .policy-content h2 {
    color: #1a472a;
    margin-top: 2rem;
    margin-bottom: 1rem;
  }

  .policy-content p {
    color: #666;
    line-height: 1.8;
  }

  .policy-content ul {
    margin: 1rem 0 1rem 2rem;
    color: #666;
  }

  .policy-content a {
    color: #1a472a;
  }
</style>
