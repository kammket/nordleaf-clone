---
import Layout from '../layouts/Layout.astro';
import { products } from '../utils/products';

const siteUrl = 'https://nordleaf.de';
const featuredProducts = products.filter(p => p.category === 'Cannabisblüten' && p.available).slice(0, 8);

const categoryStats = {
  blueten: products.filter(p => p.category === 'Cannabisblüten').length,
  extrakte: products.filter(p => p.category === 'Cannabisextrakte').length,
  vapes: products.filter(p => p.category === 'THC Vapes').length,
  shots: products.filter(p => p.category === 'THC Shots').length,
  kapseln: products.filter(p => p.category === 'Kapseln & Edibles').length,
  total: products.length,
};

const structuredData = {
  "@context": "https://schema.org",
  "@type": "MedicalBusiness",
  "name": "Nordleaf",
  "alternateName": "Nordleaf GmbH",
  "url": siteUrl,
  "logo": `${siteUrl}/favicon.svg`,
  "image": `${siteUrl}/images/og-default.png`,
  "description": "Nordleaf ist Ihre Online-Apotheke für medizinisches Cannabis in Deutschland. Cannabis auf Rezept kaufen – Cannabisblüten, Extrakte, THC Vapes und mehr ab 1€/g mit schneller Lieferung.",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Friedrichstraße 123",
    "addressLocality": "Berlin",
    "postalCode": "10117",
    "addressRegion": "BE",
    "addressCountry": "DE"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 52.5200,
    "longitude": 13.4050
  },
  "telephone": "+49-30-123456789",
  "email": "info@nordleaf.de",
  "priceRange": "€€",
  "currenciesAccepted": "EUR",
  "paymentAccepted": "Bank Transfer, Bitcoin",
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"],
    "opens": "00:00",
    "closes": "23:59"
  },
  "areaServed": {
    "@type": "Country",
    "name": "Germany"
  },
  "availableLanguage": [
    { "@type": "Language", "name": "German", "alternateName": "de" }
  ],
  "medicalSpecialty": "https://schema.org/PharmacySpecialty",
  "isAcceptingNewPatients": true,
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Medizinisches Cannabis",
    "itemListElement": [
      { "@type": "OfferCatalog", "name": "Cannabisblüten", "url": `${siteUrl}/kategorie/cannabisblueten` },
      { "@type": "OfferCatalog", "name": "Cannabisextrakte", "url": `${siteUrl}/kategorie/cannabisextrakte` },
      { "@type": "OfferCatalog", "name": "THC Vapes", "url": `${siteUrl}/kategorie/thc-vapes` },
      { "@type": "OfferCatalog", "name": "THC Shots", "url": `${siteUrl}/kategorie/thc-shots` },
      { "@type": "OfferCatalog", "name": "Kapseln & Edibles", "url": `${siteUrl}/kategorie/kapseln-edibles` }
    ]
  },
  "sameAs": []
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Nordleaf",
  "url": siteUrl,
  "description": "Online-Apotheke für medizinisches Cannabis in Deutschland",
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": `${siteUrl}/products?q={search_term_string}`
    },
    "query-input": "required name=search_term_string"
  }
};

const faqStructuredData = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Wer kann medizinisches Cannabis erhalten?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Grundsätzlich kann jeder Patient in Deutschland medizinisches Cannabis verschrieben bekommen, wenn eine ärztliche Indikation vorliegt. Häufige Anwendungsgebiete sind chronische Schmerzen, Schlafstörungen, ADHS, Depressionen und Angststörungen."
      }
    },
    {
      "@type": "Question",
      "name": "Wie kann ich medizinisches Cannabis kaufen?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Bei Nordleaf können Sie medizinisches Cannabis online kaufen. Füllen Sie einfach unseren 3-Minuten-Fragebogen aus, erhalten Sie Ihr Rezept von einem approbierten Arzt und bestellen Sie Ihre Cannabisblüten, Extrakte oder THC Vapes direkt in unserer Online-Apotheke."
      }
    },
    {
      "@type": "Question",
      "name": "Wie viel kostet das Cannabis-Rezept?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Mit unserem All-in-One Paket zahlen Sie nur €9,90 für die ärztliche Beratung und das Rezept — dazu kommen die Kosten für Ihr gewähltes Medikament. Alternativ bieten wir das Nur-Rezept-Paket für €19,90 an."
      }
    },
    {
      "@type": "Question",
      "name": "Wie schnell wird mein Cannabis geliefert?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Nach Genehmigung Ihres Rezepts versenden wir Ihr Medikament in der Regel am nächsten Werktag. Die Lieferung erfolgt innerhalb von 1-3 Werktagen diskret verpackt direkt zu Ihnen nach Hause."
      }
    },
    {
      "@type": "Question",
      "name": "Welche Cannabis-Produkte gibt es bei Nordleaf?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Nordleaf bietet über 180 medizinische Cannabis-Produkte: Cannabisblüten (THC Blüten), Cannabisextrakte (Vollspektrum-Öle), THC Vapes, THC Shots und Kapseln & Edibles. Alle Produkte sind pharmazeutisch geprüft und ab 1€/g erhältlich."
      }
    },
    {
      "@type": "Question",
      "name": "Ist Cannabis kaufen in Deutschland legal?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Ja, medizinisches Cannabis ist in Deutschland seit 2017 legal, wenn es von einem Arzt verschrieben wird. Mit einem gültigen Cannabis-Rezept können Sie THC-haltige Produkte legal in einer Apotheke oder Online-Apotheke wie Nordleaf kaufen."
      }
    },
    {
      "@type": "Question",
      "name": "Was ist der Unterschied zwischen THC und CBD Cannabis?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "THC (Tetrahydrocannabinol) ist der psychoaktive Wirkstoff in Cannabis, der schmerzlindernd und beruhigend wirkt. CBD (Cannabidiol) hat keine psychoaktive Wirkung, wirkt aber entzündungshemmend und angstlösend. Bei Nordleaf finden Sie Produkte mit verschiedenen THC- und CBD-Gehalten."
      }
    }
  ]
};

const webpageStructuredData = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Medizinisches Cannabis kaufen – Online-Apotheke Nordleaf",
  "description": "Cannabis auf Rezept kaufen bei Nordleaf. Über 180 medizinische Cannabis-Produkte: Cannabisblüten, Extrakte, THC Vapes ab 1€/g. Schnelle Lieferung in 1-3 Werktagen.",
  "url": siteUrl,
  "isPartOf": {
    "@type": "WebSite",
    "name": "Nordleaf",
    "url": siteUrl
  }
};
---

<Layout
  title="Medizinisches Cannabis kaufen | Cannabis auf Rezept ab 1€/g – Nordleaf Online-Apotheke"
  description="Medizinisches Cannabis kaufen bei Nordleaf ✓ Cannabis auf Rezept in 3 Minuten ✓ Über 180 Produkte: Cannabisblüten, THC Vapes, Extrakte ab 1€/g ✓ Lieferung in 1-3 Werktagen ✓ 100% Verfügbarkeit"
  keywords="medizinisches Cannabis, Cannabis kaufen, THC kaufen, Cannabis auf Rezept, Cannabisblüten kaufen, THC Blüten, medizinisches Cannabis bestellen, Cannabis Apotheke online, Cannabis Rezept, Online Apotheke Cannabis, Cannabisextrakte, THC Vapes kaufen, Cannabis Patient werden, Cannabis legal kaufen Deutschland, medizinisches Cannabis Deutschland"
  canonical={siteUrl}
  structuredData={structuredData}
>
<script type="application/ld+json" set:html={JSON.stringify(faqStructuredData)} />
<script type="application/ld+json" set:html={JSON.stringify(webpageStructuredData)} />
<script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
  <!-- Hero Section -->
  <section class="hero">
    <div class="container">
      <div class="hero-content">
        <div class="hero-text">
          <div class="hero-badge">
            <span class="badge-dot"></span>
            Cannabis auf Rezept
          </div>
          <h1>Werde Cannabis-Patient in <span class="highlight">3 Minuten</span></h1>
          <p class="hero-subtitle">Deine Online-Apotheke für medizinisches Cannabis. Einfach, sicher und diskret direkt zu dir nach Hause.</p>
          <ul class="hero-checks">
            <li><svg width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="10" fill="#4caf50"/><path d="M6 10l3 3 5-6" stroke="#fff" stroke-width="2" fill="none"/></svg> All-in-One ab €9,90 + Medikament</li>
            <li><svg width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="10" fill="#4caf50"/><path d="M6 10l3 3 5-6" stroke="#fff" stroke-width="2" fill="none"/></svg> Schneller 3-Minuten-Fragebogen</li>
            <li><svg width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="10" fill="#4caf50"/><path d="M6 10l3 3 5-6" stroke="#fff" stroke-width="2" fill="none"/></svg> Diskrete Lieferung in 1-3 Werktagen</li>
          </ul>
          <div class="hero-cta">
            <a href="/wie-funktionierts" class="btn btn-primary btn-lg">Jetzt Cannabis-Patient werden</a>
            <a href="/products" class="btn btn-outline btn-lg">Live-Bestand ansehen</a>
          </div>
        </div>
        <div class="hero-visual">
          <div class="hero-card">
            <div class="hero-card-inner">
              <svg viewBox="0 0 300 300" fill="none" class="hero-illustration">
                <defs>
                  <linearGradient id="heroGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                    <stop offset="0%" style="stop-color:#2d6a47"/>
                    <stop offset="100%" style="stop-color:#1a472a"/>
                  </linearGradient>
                </defs>
                <circle cx="150" cy="150" r="140" fill="url(#heroGrad)" opacity="0.15"/>
                <circle cx="150" cy="150" r="100" fill="url(#heroGrad)" opacity="0.25"/>
                <path d="M150 40 C130 80 90 100 90 140 C90 180 120 210 150 230 C180 210 210 180 210 140 C210 100 170 80 150 40Z" fill="#4caf50" opacity="0.8"/>
                <path d="M150 70 C140 95 115 110 115 140 C115 165 133 185 150 195 C167 185 185 165 185 140 C185 110 160 95 150 70Z" fill="#2d6a47"/>
                <text x="150" y="155" text-anchor="middle" fill="white" font-size="20" font-weight="700">THC</text>
                <text x="150" y="175" text-anchor="middle" fill="rgba(255,255,255,0.7)" font-size="12">Medizinisch</text>
              </svg>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Bar -->
  <section class="stats-bar">
    <div class="container">
      <div class="stats-grid">
        <div class="stat">
          <div class="stat-icon">⚡</div>
          <div class="stat-text">
            <strong>&lt; 24h</strong>
            <span>Versand</span>
          </div>
        </div>
        <div class="stat">
          <div class="stat-icon">✓</div>
          <div class="stat-text">
            <strong>100%</strong>
            <span>Verfügbarkeit</span>
          </div>
        </div>
        <div class="stat">
          <div class="stat-icon">👨‍⚕️</div>
          <div class="stat-text">
            <strong>9 Ärzte</strong>
            <span>im Netzwerk</span>
          </div>
        </div>
        <div class="stat">
          <div class="stat-icon">⭐</div>
          <div class="stat-text">
            <strong>4,77 / 5</strong>
            <span>6.502 Bewertungen</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Bekannt aus / Press Logos -->
  <section class="press-bar">
    <div class="container">
      <span class="press-label">Bekannt aus</span>
      <div class="press-logos">
        <div class="press-logo">
          <strong>Handelsblatt</strong>
        </div>
        <div class="press-logo">
          <strong>Apotheke Adhoc</strong>
        </div>
        <div class="press-logo">
          <strong>DHZ</strong>
          <span>Deutsche Hanf Zeitung</span>
        </div>
        <div class="press-logo">
          <strong>Leafly</strong>
        </div>
        <div class="press-logo">
          <strong>Business Punk</strong>
        </div>
        <div class="press-logo">
          <strong>OMR</strong>
        </div>
      </div>
    </div>
  </section>

  <!-- Social Proof Counters -->
  <section class="social-proof">
    <div class="container">
      <div class="proof-grid">
        <div class="proof-item">
          <div class="proof-number" data-count="12847">12.847+</div>
          <div class="proof-label">Zufriedene Patienten</div>
        </div>
        <div class="proof-item">
          <div class="proof-number">4,77 / 5 ⭐</div>
          <div class="proof-label">Durchschnittsbewertung</div>
        </div>
        <div class="proof-item">
          <div class="proof-number">186+</div>
          <div class="proof-label">Cannabis-Produkte</div>
        </div>
        <div class="proof-item">
          <div class="proof-number">&lt; 24h</div>
          <div class="proof-label">Rezeptausstellung</div>
        </div>
      </div>
      <div class="proof-cta">
        <a href="/erfahrungen" class="proof-link">Alle Erfahrungsberichte lesen →</a>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="how-it-works" id="wie-funktionierts">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">So einfach geht's</span>
        <h2>In 3 Schritten zu deinem Cannabis-Rezept</h2>
        <p>Von der Blütenauswahl bis zur Lieferung — alles online, alles einfach.</p>
      </div>

      <div class="steps-grid">
        <div class="step-card">
          <div class="step-number">1</div>
          <div class="step-icon">
            <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
              <rect width="48" height="48" rx="12" fill="#e8f5e9"/>
              <path d="M24 12 C20 18 14 22 14 28 C14 34 18 38 24 38 C30 38 34 34 34 28 C34 22 28 18 24 12Z" fill="#4caf50"/>
            </svg>
          </div>
          <h3>Blüten auswählen</h3>
          <p>Wähle deine gewünschten Cannabisblüten aus unserem Live-Bestand. Alle Sorten immer auf Lager.</p>
        </div>

        <div class="step-card">
          <div class="step-number">2</div>
          <div class="step-icon">
            <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
              <rect width="48" height="48" rx="12" fill="#e8f5e9"/>
              <rect x="12" y="10" width="24" height="28" rx="3" fill="#4caf50"/>
              <line x1="17" y1="18" x2="31" y2="18" stroke="white" stroke-width="2"/>
              <line x1="17" y1="24" x2="31" y2="24" stroke="white" stroke-width="2"/>
              <line x1="17" y1="30" x2="25" y2="30" stroke="white" stroke-width="2"/>
            </svg>
          </div>
          <h3>Fragebogen ausfüllen</h3>
          <p>Fülle unseren medizinischen Fragebogen in nur 3 Minuten aus. Ein Arzt prüft deine Angaben.</p>
        </div>

        <div class="step-card">
          <div class="step-number">3</div>
          <div class="step-icon">
            <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
              <rect width="48" height="48" rx="12" fill="#e8f5e9"/>
              <rect x="10" y="20" width="28" height="18" rx="3" fill="#4caf50"/>
              <path d="M10 25 L24 32 L38 25" stroke="white" stroke-width="2" fill="none"/>
              <rect x="18" y="14" width="12" height="6" rx="2" fill="#388e3c"/>
            </svg>
          </div>
          <h3>Bezahlung & Lieferung</h3>
          <p>Nach Genehmigung bezahlst du bequem online. Dein Medikament wird diskret in 1-3 Tagen geliefert.</p>
        </div>
      </div>

      <div class="steps-cta">
        <a href="/wie-funktionierts" class="btn btn-primary btn-lg">Jetzt starten</a>
      </div>
    </div>
  </section>

  <!-- Featured Products -->
  <section class="featured-products">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">Live-Bestand</span>
        <h2>Beliebte Cannabisblüten</h2>
        <p>Alle Sorten immer auf Lager — 100% Verfügbarkeit garantiert.</p>
      </div>

      <div class="products-grid">
        {featuredProducts.map((product) => (
          <a href={`/${product.slug}`} class="product-card">
            <div class="product-image">
              <img src={product.image} alt={product.strain || product.name} loading="lazy" width="300" height="300" />
              {product.badge && <span class="product-badge">{product.badge}</span>}
              <span class="availability available">Sofort lieferbar</span>
            </div>
            <div class="product-info">
              <div class="product-meta">
                <span class="product-brand">{product.brand}</span>
                <span class="product-origin">{product.originCode}</span>
              </div>
              <h3 class="product-strain">{product.strain}</h3>
              <p class="product-name">{product.name}</p>
              <div class="product-stats">
                <span class="thc">THC {product.thc}</span>
                <span class="cbd">CBD {product.cbd}</span>
              </div>
              <div class="product-effects">
                {product.effects.slice(0, 3).map((effect) => (
                  <span class="effect-tag">{effect}</span>
                ))}
              </div>
              <div class="product-price">
                <strong>€{product.price.toFixed(2)}</strong>
                <span>/ {product.priceUnit}</span>
              </div>
            </div>
          </a>
        ))}
      </div>

      <div class="products-cta">
        <a href="/products" class="btn btn-outline btn-lg">Alle Sorten ansehen →</a>
      </div>
    </div>
  </section>

  <!-- SEO Content: Medizinisches Cannabis kaufen -->
  <section class="seo-content" id="medizinisches-cannabis">
    <div class="container">
      <div class="seo-content-grid">
        <div class="seo-text">
          <span class="section-tag">Medizinisches Cannabis</span>
          <h2>Medizinisches Cannabis kaufen — einfach, legal & sicher</h2>
          <p>Bei <strong>Nordleaf</strong> können Sie <strong>medizinisches Cannabis kaufen</strong> — schnell, legal und bequem von zu Hause. Als zertifizierte <strong>Cannabis Apotheke online</strong> bieten wir Ihnen Zugang zu über <strong>{categoryStats.total} medizinischen Cannabis-Produkten</strong>, darunter hochwertige <strong>Cannabisblüten</strong>, <strong>Cannabisextrakte</strong>, <strong>THC Vapes</strong> und mehr.</p>
          <p>Seit der Legalisierung von <strong>Cannabis auf Rezept</strong> in Deutschland können Patienten mit entsprechender ärztlicher Indikation <strong>THC kaufen</strong> und von der therapeutischen Wirkung profitieren. Ob bei chronischen Schmerzen, Schlafstörungen, ADHS oder Angststörungen — <strong>medizinisches Cannabis bestellen</strong> war noch nie so einfach.</p>
          <p>Unser 3-Minuten-Fragebogen ermöglicht es Ihnen, schnell und unkompliziert ein <strong>Cannabis-Rezept</strong> zu erhalten. Ein approbierter Arzt prüft Ihre Angaben und stellt das Rezept aus. Anschließend können Sie direkt in unserem Shop Ihre <strong>THC Blüten</strong> und weitere Produkte auswählen — mit garantierter <strong>100% Verfügbarkeit</strong> und diskreter Lieferung in 1-3 Werktagen.</p>
          <div class="seo-highlights">
            <div class="seo-highlight">
              <span class="seo-highlight-icon">🏥</span>
              <div>
                <strong>Ärztlich geprüft</strong>
                <span>Approbierte Ärzte mit Cannabis-Erfahrung</span>
              </div>
            </div>
            <div class="seo-highlight">
              <span class="seo-highlight-icon">📋</span>
              <div>
                <strong>Cannabis Rezept in Minuten</strong>
                <span>3-Minuten-Fragebogen, schnelle Rezeptausstellung</span>
              </div>
            </div>
            <div class="seo-highlight">
              <span class="seo-highlight-icon">🚚</span>
              <div>
                <strong>Diskrete Lieferung</strong>
                <span>Neutrale Verpackung, 1-3 Werktage</span>
              </div>
            </div>
            <div class="seo-highlight">
              <span class="seo-highlight-icon">✅</span>
              <div>
                <strong>100% legal in Deutschland</strong>
                <span>Cannabis legal kaufen mit gültigem Rezept</span>
              </div>
            </div>
          </div>
        </div>
        <div class="seo-sidebar">
          <div class="seo-info-card">
            <h3>Cannabis auf Rezept — So funktioniert's</h3>
            <p>In Deutschland ist <strong>medizinisches Cannabis</strong> seit März 2017 für Patienten verfügbar. Seit der Teillegalisierung 2024 (CanG) wurde der Zugang weiter vereinfacht. Bei Nordleaf erhalten Sie Ihr Rezept vollständig digital — ohne Wartezeiten, ohne Praxisbesuch.</p>
            <ul class="seo-list">
              <li>Cannabis auf Rezept für chronische Schmerzen</li>
              <li>THC kaufen bei Schlafstörungen & Insomnie</li>
              <li>Cannabisblüten bei ADHS & Konzentrationsproblemen</li>
              <li>Medizinisches Cannabis bei Depressionen</li>
              <li>Cannabis-Therapie bei Angst- & Panikstörungen</li>
            </ul>
            <a href="/products" class="btn btn-primary">Cannabis kaufen →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SEO Content: Product Categories -->
  <section class="categories-seo" id="cannabis-produkte">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">Unser Sortiment</span>
        <h2>Cannabis-Produkte kaufen — {categoryStats.total}+ Sorten verfügbar</h2>
        <p>Von THC Blüten bis Cannabisextrakte: Entdecken Sie unser vollständiges Sortiment an medizinischem Cannabis.</p>
      </div>

      <div class="categories-grid">
        <a href="/products?category=Cannabisblüten" class="category-card">
          <div class="category-icon">🌿</div>
          <h3>Cannabisblüten kaufen</h3>
          <span class="category-count">{categoryStats.blueten} Sorten</span>
          <p>Hochwertige <strong>THC Blüten</strong> und <strong>Cannabisblüten</strong> von renommierten Herstellern. Indica, Sativa und Hybrid-Sorten mit verschiedenen THC- und CBD-Gehalten ab 1€/g. Perfekt für Patienten, die Wert auf natürliche Anwendung legen.</p>
        </a>

        <a href="/products?category=Cannabisextrakte" class="category-card">
          <div class="category-icon">💧</div>
