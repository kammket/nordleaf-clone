---
// Contact Page

import Layout from '../layouts/Layout.astro';

const siteUrl = 'https://nordleaf.de';

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'Contact Nordleaf',
  url: `${siteUrl}/contact`,
};
---

<Layout
  title="Contact Us - Nordleaf"
  description="Get in touch with Nordleaf. We're here to help! Contact us via email, phone, or our contact form."
  canonical={`${siteUrl}/contact`}
  ogImage="/images/og-contact.jpg"
  keywords="contact nordleaf, customer service, support, inquiries"
  structuredData={structuredData}
>
  <div class="contact-page">
    <section class="page-header">
      <div class="container">
        <h1>Contact Us</h1>
        <p>We'd Love to Hear From You</p>
      </div>
    </section>

    <section class="contact-section">
      <div class="container">
        <div class="contact-grid">
          <div class="contact-form-wrapper">
            <h2>Send us a Message</h2>
            <form class="contact-form" method="POST">
              <div class="form-group">
                <label for="name">Full Name *</label>
                <input type="text" id="name" name="name" required />
              </div>

              <div class="form-group">
                <label for="email">Email Address *</label>
                <input type="email" id="email" name="email" required />
              </div>

              <div class="form-group">
                <label for="message">Message *</label>
                <textarea id="message" name="message" rows="5" required></textarea>
              </div>

              <button type="submit" class="btn">Send Message</button>
            </form>
          </div>

          <div class="contact-info-wrapper">
            <h2>Get in Touch</h2>

            <div class="contact-info-item">
              <h3>📍 Address</h3>
              <p>Nordleaf GmbH<br />Berlin, Germany</p>
            </div>

            <div class="contact-info-item">
              <h3>📞 Phone</h3>
              <p><a href="tel:+49123456789">+49 123 456789</a></p>
            </div>

            <div class="contact-info-item">
              <h3>✉️ Email</h3>
              <p><a href="mailto:info@nordleaf.de">info@nordleaf.de</a></p>
            </div>
          </div>
        </div>
      </div>
    </section>
  </div>
</Layout>

<style>
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  .page-header {
    background: linear-gradient(135deg, #1a472a 0%, #2d6a47 100%);
    color: white;
    padding: 3rem 0;
    text-align: center;
  }

  .page-header h1 {
    color: white;
  }

  .contact-section {
    padding: 4rem 0;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
  }

  .form-group {
    margin-bottom: 1.5rem;
  }

  .form-group label {
    display: block;
    margin-bottom: 0.5rem;
    font-weight: 600;
  }

  .form-group input,
  .form-group textarea {
    width: 100%;
    padding: 0.75rem;
    border: 1px solid #ddd;
    border-radius: 0.25rem;
    font-size: 1rem;
  }

  .btn {
    padding: 0.75rem 2rem;
    background-color: #1a472a;
    color: white;
    border: none;
    border-radius: 0.5rem;
    font-weight: 600;
    cursor: pointer;
    width: 100%;
  }

  .btn:hover {
    background-color: #2d6a47;
  }

  .contact-info-item {
    margin-bottom: 2rem;
  }

  .contact-info-item h3 {
    color: #1a472a;
    margin-bottom: 0.75rem;
  }

  .contact-info-item a {
    color: #1a472a;
  }

  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
