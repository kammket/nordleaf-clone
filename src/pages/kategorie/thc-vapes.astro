---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { products } from '../../utils/products';

const siteUrl = 'https://nordleaf.de';
const categoryProducts = products.filter(p => p.category === 'THC Vapes');
const availableCount = categoryProducts.filter(p => p.available).length;
const brands = [...new Set(categoryProducts.map(p => p.brand))];
const minPrice = Math.min(...categoryProducts.map(p => p.price));

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "THC Vapes kaufen – Medizinische Cannabis Vaporizer Kartuschen",
  "description": `${categoryProducts.length} medizinische THC Vapes und Cannabis-Kartuschen ab €${minPrice.toFixed(2)}. Marken: ${brands.join(', ')}.`,
  "numberOfItems": categoryProducts.length,
  "itemListElement": categoryProducts.map((p, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": p.name,
    "url": `${siteUrl}/${p.slug}`
  }))
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Was sind medizinische THC Vapes?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Medizinische THC Vapes sind vorgefüllte Kartuschen mit Cannabis-Extrakt, die mit einem kompatiblen Vaporizer verdampft werden. Sie bieten eine kontrollierte, präzise Dosierung und sofortige Wirkung — ideal für schnelle Symptomlinderung bei Schmerzen, Übelkeit oder Angst."
      }
    },
    {
      "@type": "Question",
      "name": "Wie funktionieren THC Vape Kartuschen?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "THC Vape Kartuschen werden auf einen kompatiblen Vaporizer-Akku geschraubt. Beim Inhalieren erhitzt ein Heizelement den Cannabis-Extrakt auf die optimale Verdampfungstemperatur — ohne Verbrennung. So werden die Wirkstoffe inhaliert, ohne schädliche Verbrennungsprodukte."
      }
    },
    {
      "@type": "Question",
      "name": "Welche Vorteile haben THC Vapes gegenüber Cannabisblüten?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "THC Vapes bieten schnelle Wirkung (1-3 Minuten), diskrete Anwendung ohne starken Geruch, exakte Dosierung pro Zug, keine Verbrennungsprodukte und einfache Handhabung ohne Grinder oder Zubehör. Sie sind ideal für unterwegs und akute Symptomlinderung."
      }
    },
    {
      "@type": "Question",
      "name": "Welche THC Vape Sorten gibt es bei Nordleaf?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `Bei Nordleaf sind ${categoryProducts.length} THC Vape Kartuschen verfügbar, darunter Indica-, Sativa- und Hybrid-Sorten von Marken wie ${brands.join(', ')}. Die Kartuschen enthalten verschiedene Terpene-Profile und THC-Konzentrationen für unterschiedliche Wirkungen.`
      }
    },
    {
      "@type": "Question",
      "name": "Benötige ich ein Rezept für THC Vapes?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Ja, medizinische THC Vapes sind verschreibungspflichtig. Bei Nordleaf können Sie Ihr Rezept einfach online erhalten: Füllen Sie den 3-Minuten-Fragebogen aus, ein approbierter Arzt prüft Ihre Angaben, und bei Eignung erhalten Sie Ihr Rezept ab €9,90."
      }
    }
  ]
};
---

<Layout
  title="THC Vapes kaufen | Cannabis Vaporizer Kartuschen auf Rezept – Nordleaf"
  description={`${categoryProducts.length} medizinische THC Vapes auf Rezept ✓ Cannabis Kartuschen ab €${minPrice.toFixed(2)} ✓ Marken: ${brands.join(', ')} ✓ Sofortige Wirkung ✓ Diskret & geruchsarm ✓ Lieferung in 1-3 Werktagen`}
  keywords="THC Vape kaufen, Cannabis Vape bestellen, THC Kartusche, medizinischer Vaporizer, Cannabis Vaporizer Kartuschen, THC Vape Pen, Cannabis inhalieren, THC Vape auf Rezept, Vape Pen Deutschland"
  structuredData={itemListSchema}
>
<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

<Breadcrumb items={[{name: "Live-Bestand", url: "/products"}, {name: "THC Vapes"}]} />

<!-- Hero -->
<section class="cat-hero">
  <div class="container">
    <div class="cat-hero-content">
      <span class="cat-badge">💨 {availableCount} Vapes verfügbar</span>
      <h1>THC Vapes <span class="hl">kaufen</span></h1>
      <p>Medizinische Cannabis Vaporizer Kartuschen auf Rezept. {categoryProducts.length} THC Vapes verschiedener Sorten — sofortige Wirkung, diskret und geruchsarm.</p>
      <div class="cat-hero-stats">
        <div class="stat"><strong>{categoryProducts.length}</strong><span>Vapes</span></div>
        <div class="stat"><strong>{brands.length}</strong><span>Marken</span></div>
        <div class="stat"><strong>ab €{minPrice.toFixed(2)}</strong><span>pro Kartusche</span></div>
        <div class="stat"><strong>1-3 Min</strong><span>Wirkungseintritt</span></div>
      </div>
      <a href="/wie-funktionierts" class="btn-cta">Rezept in 3 Minuten →</a>
    </div>
  </div>
</section>

<!-- SEO Content -->
<section class="info-section">
  <div class="container">
    <div class="info-grid">
      <div class="info-block">
        <h2>Was sind medizinische THC Vapes?</h2>
        <p>THC Vapes sind vorgefüllte Kartuschen mit <strong>hochwertigem Cannabis-Extrakt</strong>, die mit einem kompatiblen Vaporizer-Akku verdampft werden. Anders als beim Rauchen entstehen dabei keine Verbrennungsprodukte — die Wirkstoffe werden schonend bei optimaler Temperatur freigesetzt.</p>
        <p>Die Wirkung tritt <strong>innerhalb von 1-3 Minuten</strong> ein und ist damit die schnellste aller Einnahmeformen. Das macht THC Vapes ideal für akute Symptomlinderung — etwa bei plötzlichen Schmerzspitzen, Übelkeit oder Angstattacken.</p>
        <p>Bei Nordleaf finden Sie {categoryProducts.length} verschiedene Vape Kartuschen in Indica-, Sativa- und Hybrid-Sorten von renommierten Herstellern wie {brands.join(', ')}.</p>
      </div>
      <div class="info-block">
        <h2>Vorteile von Cannabis Vapes</h2>
        <ul>
          <li><strong>Sofortige Wirkung:</strong> Wirkungseintritt in 1-3 Minuten — schneller als jede andere Einnahmeform</li>
          <li><strong>Diskret & geruchsarm:</strong> Kaum wahrnehmbarer Geruch, ideal für unterwegs</li>
          <li><strong>Präzise Dosierung:</strong> Kontrollierte Wirkstoffmenge pro Zug</li>
          <li><strong>Keine Verbrennung:</strong> Verdampfung statt Rauch — schonender für die Atemwege</li>
          <li><strong>Einfache Handhabung:</strong> Kartusche aufschrauben, inhalieren — kein Grinder oder Zubehör nötig</li>
          <li><strong>Verschiedene Sorten:</strong> Indica, Sativa & Hybrid mit verschiedenen Terpene-Profilen</li>
        </ul>
      </div>
    </div>
  </div>
</section>

<!-- Brands -->
<section class="brands-section">
  <div class="container">
    <h2 class="section-title">Unsere THC Vape Marken</h2>
    <div class="brands-grid">
      {brands.map((brand) => {
        const brandProducts = categoryProducts.filter(p => p.brand === brand);
        const brandMinPrice = Math.min(...brandProducts.map(p => p.price));
        return (
          <div class="brand-card">
            <h3>{brand}</h3>
            <div class="brand-meta">
              <span>{brandProducts.length} Sorten</span>
              <span>ab €{brandMinPrice.toFixed(2)}</span>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>

<!-- Products Grid -->
<section class="products-section">
  <div class="container">
    <h2 class="section-title">Alle {categoryProducts.length} THC Vapes</h2>
    <div class="products-grid">
      {categoryProducts.map((product) => (
        <a href={`/${product.slug}`} class="product-card">
          <div class="product-image vape">
            <img src={product.image} alt={`${product.name} - THC Vape kaufen`} loading="lazy" width="300" height="160" />
            {product.badge && <span class="product-badge">{product.badge}</span>}
            <span class={`availability ${product.available ? 'available' : 'unavailable'}`}>
              {product.available ? 'Sofort lieferbar' : 'Ausverkauft'}
            </span>
          </div>
          <div class="product-info">
            <div class="product-meta">
              <span class="product-brand">{product.brand}</span>
              <span class="product-origin">{product.originCode}</span>
            </div>
            <h3 class="product-strain">{product.strain}</h3>
            <p class="product-name">{product.name}</p>
            <div class="product-stats">
              <span class="thc">THC {product.thc}</span>
              <span class="cbd">CBD {product.cbd}</span>
            </div>
            <div class="product-effects">
              {product.effects.map((effect) => (
                <span class="effect-tag">{effect}</span>
              ))}
            </div>
            <div class="product-footer">
              <div class="product-price">
                <strong>€{product.price.toFixed(2)}</strong>
                <span>/ Kartusche</span>
              </div>
              <span class="btn-add">Ansehen</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- Buying Guide -->
<section class="guide-section">
  <div class="container">
    <h2>THC Vapes kaufen: So funktioniert's</h2>
    <div class="steps-grid">
      <div class="step">
        <div class="step-num">1</div>
        <h3>Vape Sorte wählen</h3>
        <p>Wähle deine bevorzugte Sorte — Indica für Entspannung, Sativa für Energie oder Hybrid für Balance.</p>
      </div>
      <div class="step">
        <div class="step-num">2</div>
        <h3>Rezept erhalten</h3>
        <p>Fülle unseren 3-Minuten-Fragebogen aus. Ein approbierter Arzt prüft deine Angaben und stellt dein Rezept aus.</p>
      </div>
      <div class="step">
        <div class="step-num">3</div>
        <h3>Diskret geliefert</h3>
        <p>Dein THC Vape wird innerhalb von 1-3 Werktagen diskret verpackt direkt zu dir geliefert.</p>
      </div>
    </div>
  </div>
</section>

<!-- FAQ -->
<section class="faq-section">
  <div class="container">
    <h2>Häufige Fragen zu THC Vapes</h2>
    <div class="faq-list">
      <details class="faq-item">
        <summary>Was sind medizinische THC Vapes?</summary>
        <p>Medizinische THC Vapes sind vorgefüllte Kartuschen mit Cannabis-Extrakt, die mit einem Vaporizer verdampft werden. Sie bieten eine kontrollierte Dosierung und sofortige Wirkung — ideal für schnelle Symptomlinderung.</p>
      </details>
      <details class="faq-item">
        <summary>Wie funktionieren THC Vape Kartuschen?</summary>
        <p>Die Kartusche wird auf einen Vaporizer-Akku geschraubt. Beim Inhalieren erhitzt ein Heizelement den Cannabis-Extrakt auf die optimale Verdampfungstemperatur — ohne Verbrennung und ohne schädliche Verbrennungsprodukte.</p>
      </details>
      <details class="faq-item">
        <summary>Welche Vorteile haben THC Vapes gegenüber Blüten?</summary>
        <p>Schnellere Wirkung (1-3 Minuten), praktisch kein Geruch, exakte Dosierung, keine Verbrennung und einfache Handhabung ohne Zubehör. Ideal für diskrete Anwendung und unterwegs.</p>
      </details>
      <details class="faq-item">
        <summary>Welche Sorten gibt es als THC Vape?</summary>
        <p>Bei Nordleaf finden Sie {categoryProducts.length} THC Vapes in Indica-, Sativa- und Hybrid-Sorten von {brands.join(', ')}. Jede Sorte hat ein eigenes Terpene-Profil für unterschiedliche Wirkungen und Geschmacksrichtungen.</p>
      </details>
      <details class="faq-item">
        <summary>Benötige ich ein Rezept für THC Vapes?</summary>
        <p>Ja, THC Vapes sind verschreibungspflichtig. Bei Nordleaf erhalten Sie Ihr Rezept einfach online: 3-Minuten-Fragebogen ausfüllen, ärztliche Prüfung, Rezept ab €9,90.</p>
      </details>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="cta-section">
  <div class="container">
    <div class="cta-box">
      <h2>THC Vapes auf Rezept bestellen</h2>
      <p>{categoryProducts.length} Vape-Sorten verfügbar — Rezept in 3 Minuten, Lieferung in 1-3 Werktagen</p>
      <div class="cta-buttons">
        <a href="/wie-funktionierts" class="btn-primary btn-lg">Jetzt Rezept anfordern</a>
        <a href="/products" class="btn-secondary">Alle Produkte ansehen</a>
      </div>
    </div>
  </div>
</section>
</Layout>

<style>
  .cat-hero { background: linear-gradient(135deg, #1a1a2e, #16213e, #0f3460); color: white; padding: 3rem 1.5rem 3.5rem; text-align: center; }
  .cat-badge { display: inline-block; background: rgba(76,175,80,0.2); color: #8bc34a; padding: 0.4rem 1rem; border-radius: 50px; font-size: 0.85rem; font-weight: 600; margin-bottom: 1rem; }
  .cat-hero h1 { font-size: 2.5rem; font-weight: 800; margin-bottom: 1rem; line-height: 1.15; }
  .cat-hero .hl { color: #8bc34a; }
  .cat-hero p { color: rgba(255,255,255,0.8); font-size: 1.1rem; max-width: 700px; margin: 0 auto 1.5rem; line-height: 1.6; }
  .cat-hero-stats { display: flex; justify-content: center; gap: 2rem; margin-bottom: 1.5rem; flex-wrap: wrap; }
  .cat-hero-stats .stat { display: flex; flex-direction: column; align-items: center; }
  .cat-hero-stats strong { font-size: 1.3rem; color: white; }
  .cat-hero-stats span { font-size: 0.8rem; color: rgba(255,255,255,0.6); }
  .btn-cta { display: inline-block; background: #4caf50; color: white; padding: 0.8rem 2rem; border-radius: 50px; font-weight: 600; font-size: 1rem; transition: all 0.2s; text-decoration: none; }
  .btn-cta:hover { background: #43a047; transform: translateY(-2px); box-shadow: 0 4px 15px rgba(76,175,80,0.4); }
  .info-section { padding: 3rem 1.5rem; background: white; }
  .info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2.5rem; }
  .info-block h2 { font-size: 1.4rem; font-weight: 700; color: #1a472a; margin-bottom: 1rem; }
  .info-block p { color: #555; line-height: 1.7; font-size: 0.95rem; margin-bottom: 0.75rem; }
  .info-block ul { list-style: none; padding: 0; }
  .info-block ul li { padding: 0.5rem 0; color: #555; font-size: 0.95rem; line-height: 1.5; padding-left: 1.5rem; position: relative; }
  .info-block ul li::before { content: '✓'; position: absolute; left: 0; color: #4caf50; font-weight: 700; }
  .brands-section { padding: 2.5rem 1.5rem; background: #f8faf9; }
  .brands-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; }
  .brand-card { background: white; border: 1px solid #e8ede9; border-radius: 10px; padding: 1.25rem; text-align: center; }
  .brand-card h3 { font-size: 1.05rem; font-weight: 700; color: #1a472a; margin-bottom: 0.5rem; }
  .brand-meta { display: flex; justify-content: center; gap: 1rem; }
  .brand-meta span { font-size: 0.8rem; color: #888; }
  .products-section { padding: 2.5rem 1.5rem 3rem; background: #f8faf9; }
  .section-title { font-size: 1.5rem; font-weight: 700; color: #1a472a; margin-bottom: 1.5rem; }
  .products-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; }
  .product-card { background: white; border: 1px solid #e8ede9; border-radius: 12px; overflow: hidden; transition: all 0.3s; display: flex; flex-direction: column; text-decoration: none; color: inherit; }
  .product-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0,0,0,0.08); border-color: #4caf50; }
  .product-image { position: relative; min-height: 160px; overflow: hidden; }
  .product-image.vape { background: linear-gradient(135deg, #1a1a2e, #16213e); }
  .product-image img { width: 100%; height: 160px; object-fit: contain; padding: 0.5rem; }
  .product-badge { position: absolute; top: 8px; left: 8px; background: #ff9800; color: white; padding: 0.2rem 0.6rem; border-radius: 4px; font-size: 0.7rem; font-weight: 700; text-transform: uppercase; }
  .availability { position: absolute; top: 8px; right: 8px; padding: 0.2rem 0.5rem; border-radius: 4px; font-size: 0.7rem; font-weight: 600; }
  .available { background: rgba(76,175,80,0.2); color: #4caf50; }
  .unavailable { background: rgba(244,67,54,0.15); color: #f44336; }
  .product-info { padding: 1rem; flex: 1; display: flex; flex-direction: column; }
  .product-meta { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.3rem; }
  .product-brand { color: #999; font-size: 0.75rem; }
  .product-origin { background: #f0f0f0; color: #666; padding: 0.1rem 0.4rem; border-radius: 3px; font-size: 0.7rem; font-weight: 600; }
  .product-strain { font-size: 0.95rem; font-weight: 700; color: #1a472a; margin-bottom: 0.15rem; line-height: 1.2; }
  .product-name { font-size: 0.72rem; color: #aaa; margin-bottom: 0.5rem; line-height: 1.3; }
  .product-stats { display: flex; gap: 0.4rem; margin-bottom: 0.4rem; }
  .thc, .cbd { font-size: 0.72rem; font-weight: 600; padding: 0.15rem 0.4rem; border-radius: 4px; }
  .thc { background: #e8f5e9; color: #2d6a47; }
  .cbd { background: #e3f2fd; color: #1565c0; }
  .product-effects { display: flex; flex-wrap: wrap; gap: 0.25rem; margin-bottom: 0.75rem; }
  .effect-tag { font-size: 0.68rem; color: #888; background: #f5f5f5; padding: 0.12rem 0.35rem; border-radius: 3px; }
  .product-footer { margin-top: auto; display: flex; align-items: center; justify-content: space-between; padding-top: 0.5rem; border-top: 1px solid #f0f0f0; }
  .product-price strong { font-size: 1.1rem; color: #1a472a; }
  .product-price span { font-size: 0.8rem; color: #999; }
  .btn-add { background: #4caf50; color: white; padding: 0.4rem 0.8rem; border-radius: 6px; font-size: 0.8rem; font-weight: 600; }
  .guide-section { padding: 3rem 1.5rem; background: white; }
  .guide-section h2 { font-size: 1.5rem; font-weight: 700; color: #1a472a; margin-bottom: 2rem; text-align: center; }
  .steps-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; }
  .step { text-align: center; padding: 1.5rem; }
  .step-num { width: 48px; height: 48px; background: #e8f5e9; color: #2d6a47; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.25rem; font-weight: 800; margin: 0 auto 1rem; }
  .step h3 { font-size: 1.1rem; font-weight: 700; color: #1a472a; margin-bottom: 0.5rem; }
  .step p { color: #666; font-size: 0.9rem; line-height: 1.6; }
  .faq-section { padding: 3rem 1.5rem; background: #f8faf9; }
  .faq-section h2 { font-size: 1.5rem; font-weight: 700; color: #1a472a; margin-bottom: 1.5rem; text-align: center; }
  .faq-list { max-width: 800px; margin: 0 auto; }
  .faq-item { background: white; border: 1px solid #e8ede9; border-radius: 10px; margin-bottom: 0.75rem; overflow: hidden; }
  .faq-item summary { padding: 1rem 1.25rem; font-weight: 600; color: #1a472a; cursor: pointer; font-size: 0.95rem; }
  .faq-item summary:hover { color: #4caf50; }
  .faq-item p { padding: 0 1.25rem 1rem; color: #555; line-height: 1.6; font-size: 0.9rem; }
  .cta-section { padding: 0 1.5rem 3rem; background: #f8faf9; }
  .cta-box { background: linear-gradient(135deg, #1a1a2e, #16213e, #0f3460); border-radius: 16px; padding: 3rem; text-align: center; color: white; }
  .cta-box h2 { font-size: 1.75rem; font-weight: 800; margin-bottom: 0.5rem; }
  .cta-box p { color: rgba(255,255,255,0.75); margin-bottom: 1.5rem; }
  .cta-buttons { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
  .btn-primary { background: #4caf50; color: white; padding: 0.8rem 1.75rem; border-radius: 50px; font-weight: 600; transition: all 0.2s; text-decoration: none; }
  .btn-primary:hover { background: #43a047; transform: translateY(-2px); box-shadow: 0 4px 15px rgba(76,175,80,0.4); }
  .btn-lg { padding: 0.9rem 2rem; font-size: 1.05rem; }
  .btn-secondary { background: transparent; color: white; padding: 0.8rem 1.75rem; border-radius: 50px; font-weight: 600; border: 2px solid rgba(255,255,255,0.3); transition: all 0.2s; text-decoration: none; }
  .btn-secondary:hover { border-color: white; background: rgba(255,255,255,0.1); }
  @media (max-width: 968px) {
    .info-grid { grid-template-columns: 1fr; }
    .products-grid { grid-template-columns: repeat(2, 1fr); }
    .brands-grid { grid-template-columns: repeat(2, 1fr); }
    .steps-grid { grid-template-columns: 1fr; }
    .cat-hero h1 { font-size: 2rem; }
  }
  @media (max-width: 576px) {
    .products-grid { grid-template-columns: 1fr; max-width: 380px; margin: 0 auto; }
    .brands-grid { grid-template-columns: 1fr; }
    .cat-hero h1 { font-size: 1.5rem; }
    .cta-box { padding: 2rem 1.5rem; }
  }
</style>
