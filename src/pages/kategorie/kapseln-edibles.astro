---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { products } from '../../utils/products';

const siteUrl = 'https://nordleaf.de';
const categoryProducts = products.filter(p => p.category === 'Kapseln & Edibles');
const availableCount = categoryProducts.filter(p => p.available).length;
const brands = [...new Set(categoryProducts.map(p => p.brand))];
const minPrice = Math.min(...categoryProducts.map(p => p.price));

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "THC Kapseln & Cannabis Edibles kaufen – Medizinische Cannabis Kapseln",
  "description": `Medizinische THC Kapseln und Cannabis Edibles ab €${minPrice.toFixed(2)}. Präzise dosierte Kapseln für einfache orale Einnahme.`,
  "numberOfItems": categoryProducts.length,
  "itemListElement": categoryProducts.map((p, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": p.name,
    "url": `${siteUrl}/${p.slug}`
  }))
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Was sind THC Kapseln?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "THC Kapseln (auch Dronabinol-Kapseln) sind medizinische Cannabis-Zubereitungen in Kapselform. Sie enthalten eine exakt dosierte Menge THC oder Dronabinol und werden wie normale Medikamente mit Wasser eingenommen — die einfachste und diskreteste Form der Cannabis-Medikation."
      }
    },
    {
      "@type": "Question",
      "name": "Wie wirken Cannabis Kapseln?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Cannabis Kapseln werden oral eingenommen und im Magen-Darm-Trakt aufgenommen. Die Wirkung tritt nach 30-90 Minuten ein und hält 6-8 Stunden an. Die Wirkung ist gleichmäßig und gut vorhersagbar dank der exakten Dosierung."
      }
    },
    {
      "@type": "Question",
      "name": "Was ist der Vorteil von Kapseln gegenüber Cannabisblüten?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Cannabis Kapseln bieten maximale Einfachheit: exakte, reproduzierbare Dosierung, keine Inhalation, kein Geschmack, kein Geruch, kein Zubehör. Sie werden wie normale Tabletten eingenommen und sind damit die diskreteste Form der Cannabis-Medikation."
      }
    },
    {
      "@type": "Question",
      "name": "Für wen eignen sich Cannabis Kapseln?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Cannabis Kapseln eignen sich besonders für Patienten, die eine rauchfreie, geruchlose und maximal einfache Einnahme wünschen. Ideal für Cannabis-Einsteiger, Senioren, und Patienten, die Cannabis unauffällig wie reguläre Medikamente einnehmen möchten."
      }
    },
    {
      "@type": "Question",
      "name": "Benötige ich ein Rezept für Cannabis Kapseln?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `Ja, THC Kapseln und Cannabis Edibles sind verschreibungspflichtig. Bei Nordleaf ist die Kapselvariante ab €${minPrice.toFixed(2)} erhältlich. Das Rezept erhalten Sie über unseren 3-Minuten-Fragebogen ab €9,90.`
      }
    }
  ]
};
---

<Layout
  title="THC Kapseln & Cannabis Edibles kaufen | Dronabinol Kapseln auf Rezept – Nordleaf"
  description={`Medizinische THC Kapseln & Cannabis Edibles auf Rezept ✓ Dronabinol Kapseln ab €${minPrice.toFixed(2)} ✓ Exakte Dosierung ✓ Rauchfrei & geruchlos ✓ Einfach wie eine Tablette ✓ Lieferung in 1-3 Werktagen`}
  keywords="THC Kapseln kaufen, Cannabis Edibles bestellen, Dronabinol Kapseln, Cannabis Kapseln auf Rezept, THC Tabletten, Cannabis Edibles Deutschland, Dronabinol kaufen, medizinische Cannabis Kapseln"
  structuredData={itemListSchema}
>
<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

<Breadcrumb items={[{name: "Live-Bestand", url: "/products"}, {name: "Kapseln & Edibles"}]} />

<!-- Hero -->
<section class="cat-hero">
  <div class="container">
    <div class="cat-hero-content">
      <span class="cat-badge">💊 Kapseln verfügbar</span>
      <h1>THC Kapseln & Edibles <span class="hl">kaufen</span></h1>
      <p>Medizinische Cannabis Kapseln auf Rezept. Exakt dosiert, rauchfrei und so einfach wie eine Tablette — die diskreteste Form der Cannabis-Medikation.</p>
      <div class="cat-hero-stats">
        <div class="stat"><strong>{categoryProducts.length}</strong><span>{categoryProducts.length === 1 ? 'Produkt' : 'Produkte'}</span></div>
        <div class="stat"><strong>{brands.length}</strong><span>{brands.length === 1 ? 'Marke' : 'Marken'}</span></div>
        <div class="stat"><strong>ab €{minPrice.toFixed(2)}</strong><span>pro Packung</span></div>
        <div class="stat"><strong>6-8 Std.</strong><span>Wirkdauer</span></div>
      </div>
      <a href="/wie-funktionierts" class="btn-cta">Rezept in 3 Minuten →</a>
    </div>
  </div>
</section>

<!-- SEO Content -->
<section class="info-section">
  <div class="container">
    <div class="info-grid">
      <div class="info-block">
        <h2>Was sind THC Kapseln & Cannabis Edibles?</h2>
        <p>THC Kapseln — auch bekannt als <strong>Dronabinol-Kapseln</strong> — sind medizinische Cannabis-Zubereitungen in Kapselform. Sie enthalten eine exakt definierte Menge des Wirkstoffs THC (Dronabinol) und werden oral mit Wasser eingenommen.</p>
        <p>Cannabis Edibles wie Kapseln bieten die <strong>einfachste und diskreteste Einnahmeform</strong> — sie werden genau wie herkömmliche Medikamente eingenommen. Kein Inhalieren, kein Tropfenzählen, kein Vaporizer, kein Geruch.</p>
        <p>Die Wirkung tritt nach 30-90 Minuten ein und hält <strong>6-8 Stunden gleichmäßig an</strong>. Die exakte Dosierung pro Kapsel macht diese Darreichungsform besonders geeignet für Patienten, die eine kontrollierte, verlässliche Medikation benötigen.</p>
      </div>
      <div class="info-block">
        <h2>Vorteile von Cannabis Kapseln</h2>
        <ul>
          <li><strong>Maximale Einfachheit:</strong> Einnahme wie eine normale Tablette — mit Wasser schlucken</li>
          <li><strong>Exakte Dosierung:</strong> Jede Kapsel enthält eine präzise Wirkstoffmenge</li>
          <li><strong>Komplett rauchfrei:</strong> Keine Inhalation, keine Belastung der Atemwege</li>
          <li><strong>Geruch- & geschmacklos:</strong> Kein Cannabis-Geschmack oder -Geruch</li>
          <li><strong>Diskret:</strong> Sieht aus wie normale Medikation — maximal unauffällig</li>
          <li><strong>Langanhaltende Wirkung:</strong> 6-8 Stunden gleichmäßige Wirkung</li>
        </ul>
      </div>
    </div>
  </div>
</section>

<!-- Comparison Section -->
<section class="compare-section">
  <div class="container">
    <h2 class="section-title">Cannabis Kapseln vs. andere Darreichungsformen</h2>
    <div class="compare-grid">
      <div class="compare-card active">
        <h3>💊 Kapseln & Edibles</h3>
        <ul>
          <li>Wirkungseintritt: 30-90 Min</li>
          <li>Wirkdauer: 6-8 Stunden</li>
          <li>Einnahme: Oral (schlucken)</li>
          <li>Dosierung: Exakt pro Kapsel</li>
          <li>Geruch: Keiner</li>
        </ul>
      </div>
      <div class="compare-card">
        <h3>🌿 Cannabisblüten</h3>
        <ul>
          <li>Wirkungseintritt: 1-5 Min</li>
          <li>Wirkdauer: 2-4 Stunden</li>
          <li>Einnahme: Inhalation</li>
          <li>Dosierung: Variabel</li>
          <li>Geruch: Stark</li>
        </ul>
      </div>
      <div class="compare-card">
        <h3>💧 Extrakte/Öle</h3>
        <ul>
          <li>Wirkungseintritt: 15-45 Min</li>
          <li>Wirkdauer: 4-6 Stunden</li>
          <li>Einnahme: Sublingual</li>
          <li>Dosierung: Tropfenweise</li>
          <li>Geruch: Leicht</li>
        </ul>
      </div>
    </div>
  </div>
</section>

<!-- Products Grid -->
<section class="products-section">
  <div class="container">
    <h2 class="section-title">Kapseln & Edibles im Sortiment</h2>
    <div class="products-grid">
      {categoryProducts.map((product) => (
        <a href={`/${product.slug}`} class="product-card">
          <div class="product-image kapsel">
            <img src={product.image} alt={`${product.name} - THC Kapsel kaufen`} loading="lazy" width="300" height="160" />
            {product.badge && <span class="product-badge">{product.badge}</span>}
            <span class={`availability ${product.available ? 'available' : 'unavailable'}`}>
              {product.available ? 'Sofort lieferbar' : 'Ausverkauft'}
            </span>
          </div>
          <div class="product-info">
            <div class="product-meta">
              <span class="product-brand">{product.brand}</span>
              <span class="product-origin">{product.originCode}</span>
            </div>
            <h3 class="product-strain">{product.strain}</h3>
            <p class="product-name">{product.name}</p>
            <div class="product-stats">
              <span class="thc">THC {product.thc}</span>
              <span class="cbd">CBD {product.cbd}</span>
            </div>
            <div class="product-effects">
              {product.effects.map((effect) => (
                <span class="effect-tag">{effect}</span>
              ))}
            </div>
            <div class="product-footer">
              <div class="product-price">
                <strong>€{product.price.toFixed(2)}</strong>
                <span>/ Packung</span>
              </div>
              <span class="btn-add">Ansehen</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- Buying Guide -->
<section class="guide-section">
  <div class="container">
    <h2>Cannabis Kapseln kaufen: So funktioniert's</h2>
    <div class="steps-grid">
      <div class="step">
        <div class="step-num">1</div>
        <h3>Produkt auswählen</h3>
        <p>Wähle die passende Cannabis Kapsel — Dronabinol-Kapseln mit verschiedenen Dosierungen verfügbar.</p>
      </div>
      <div class="step">
        <div class="step-num">2</div>
        <h3>Rezept erhalten</h3>
        <p>Fülle unseren 3-Minuten-Fragebogen aus. Ein approbierter Arzt prüft deine Angaben und stellt dein Rezept aus.</p>
      </div>
      <div class="step">
        <div class="step-num">3</div>
        <h3>Diskret geliefert</h3>
        <p>Deine Cannabis Kapseln werden innerhalb von 1-3 Werktagen diskret verpackt direkt zu dir geliefert.</p>
      </div>
    </div>
  </div>
</section>

<!-- FAQ -->
<section class="faq-section">
  <div class="container">
    <h2>Häufige Fragen zu Cannabis Kapseln</h2>
    <div class="faq-list">
      <details class="faq-item">
        <summary>Was sind THC Kapseln?</summary>
        <p>THC Kapseln (Dronabinol-Kapseln) sind medizinische Cannabis-Zubereitungen in Kapselform mit exakt dosiertem THC-Gehalt. Sie werden oral eingenommen — genauso einfach wie eine normale Tablette.</p>
      </details>
      <details class="faq-item">
        <summary>Wie wirken Cannabis Kapseln?</summary>
        <p>Cannabis Kapseln wirken nach 30-90 Minuten und halten 6-8 Stunden an. Die Wirkung ist gleichmäßig und durch die exakte Dosierung pro Kapsel gut vorhersagbar.</p>
      </details>
      <details class="faq-item">
        <summary>Was ist der Vorteil gegenüber Cannabisblüten?</summary>
        <p>Kapseln bieten maximale Einfachheit und Diskretion: exakte Dosierung, kein Inhalieren, kein Geruch, kein Geschmack, kein Zubehör. Ideal für Patienten, die Cannabis unauffällig einnehmen möchten.</p>
      </details>
      <details class="faq-item">
        <summary>Für wen eignen sich Cannabis Kapseln?</summary>
        <p>Cannabis Kapseln sind ideal für Einsteiger, Senioren und alle Patienten, die eine rauchfreie, geruchlose und maximal einfache Cannabis-Medikation bevorzugen.</p>
      </details>
      <details class="faq-item">
        <summary>Benötige ich ein Rezept?</summary>
        <p>Ja, THC Kapseln sind verschreibungspflichtig. Bei Nordleaf erhalten Sie Ihr Rezept einfach online: 3-Minuten-Fragebogen ausfüllen, ärztliche Prüfung, Rezept ab €9,90.</p>
      </details>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="cta-section">
  <div class="container">
    <div class="cta-box">
      <h2>Cannabis Kapseln auf Rezept bestellen</h2>
      <p>THC Kapseln & Edibles verfügbar — Rezept in 3 Minuten, Lieferung in 1-3 Werktagen</p>
      <div class="cta-buttons">
        <a href="/wie-funktionierts" class="btn-primary btn-lg">Jetzt Rezept anfordern</a>
        <a href="/products" class="btn-secondary">Alle Produkte ansehen</a>
      </div>
    </div>
  </div>
</section>
</Layout>

<style>
  .cat-hero { background: linear-gradient(135deg, #1b3a4b, #274c5e, #3a6b7e); color: white; padding: 3rem 1.5rem 3.5rem; text-align: center; }
  .cat-badge { display: inline-block; background: rgba(76,175,80,0.2); color: #8bc34a; padding: 0.4rem 1rem; border-radius: 50px; font-size: 0.85rem; font-weight: 600; margin-bottom: 1rem; }
  .cat-hero h1 { font-size: 2.5rem; font-weight: 800; margin-bottom: 1rem; line-height: 1.15; }
  .cat-hero .hl { color: #8bc34a; }
  .cat-hero p { color: rgba(255,255,255,0.8); font-size: 1.1rem; max-width: 700px; margin: 0 auto 1.5rem; line-height: 1.6; }
  .cat-hero-stats { display: flex; justify-content: center; gap: 2rem; margin-bottom: 1.5rem; flex-wrap: wrap; }
  .cat-hero-stats .stat { display: flex; flex-direction: column; align-items: center; }
  .cat-hero-stats strong { font-size: 1.3rem; color: white; }
  .cat-hero-stats span { font-size: 0.8rem; color: rgba(255,255,255,0.6); }
  .btn-cta { display: inline-block; background: #4caf50; color: white; padding: 0.8rem 2rem; border-radius: 50px; font-weight: 600; font-size: 1rem; transition: all 0.2s; text-decoration: none; }
  .btn-cta:hover { background: #43a047; transform: translateY(-2px); box-shadow: 0 4px 15px rgba(76,175,80,0.4); }
  .info-section { padding: 3rem 1.5rem; background: white; }
  .info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2.5rem; }
  .info-block h2 { font-size: 1.4rem; font-weight: 700; color: #1a472a; margin-bottom: 1rem; }
  .info-block p { color: #555; line-height: 1.7; font-size: 0.95rem; margin-bottom: 0.75rem; }
  .info-block ul { list-style: none; padding: 0; }
  .info-block ul li { padding: 0.5rem 0; color: #555; font-size: 0.95rem; line-height: 1.5; padding-left: 1.5rem; position: relative; }
  .info-block ul li::before { content: '✓'; position: absolute; left: 0; color: #4caf50; font-weight: 700; }
  .compare-section { padding: 2.5rem 1.5rem; background: #f8faf9; }
  .compare-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; }
  .compare-card { background: white; border: 1px solid #e8ede9; border-radius: 12px; padding: 1.5rem; }
  .compare-card.active { border-color: #4caf50; background: #f0faf0; }
  .compare-card h3 { font-size: 1.1rem; font-weight: 700; color: #1a472a; margin-bottom: 0.75rem; }
  .compare-card ul { list-style: none; padding: 0; }
  .compare-card ul li { padding: 0.35rem 0; color: #555; font-size: 0.85rem; border-bottom: 1px solid #f0f0f0; }
  .compare-card ul li:last-child { border-bottom: none; }
  .products-section { padding: 2.5rem 1.5rem 3rem; background: white; }
  .section-title { font-size: 1.5rem; font-weight: 700; color: #1a472a; margin-bottom: 1.5rem; }
  .products-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; max-width: 800px; }
  .product-card { background: white; border: 1px solid #e8ede9; border-radius: 12px; overflow: hidden; transition: all 0.3s; display: flex; flex-direction: column; text-decoration: none; color: inherit; }
  .product-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0,0,0,0.08); border-color: #4caf50; }
  .product-image { position: relative; min-height: 160px; overflow: hidden; }
  .product-image.kapsel { background: linear-gradient(135deg, #1b3a4b, #274c5e); }
  .product-image img { width: 100%; height: 160px; object-fit: contain; padding: 0.5rem; }
  .product-badge { position: absolute; top: 8px; left: 8px; background: #ff9800; color: white; padding: 0.2rem 0.6rem; border-radius: 4px; font-size: 0.7rem; font-weight: 700; text-transform: uppercase; }
  .availability { position: absolute; top: 8px; right: 8px; padding: 0.2rem 0.5rem; border-radius: 4px; font-size: 0.7rem; font-weight: 600; }
  .available { background: rgba(76,175,80,0.2); color: #4caf50; }
  .unavailable { background: rgba(244,67,54,0.15); color: #f44336; }
  .product-info { padding: 1rem; flex: 1; display: flex; flex-direction: column; }
  .product-meta { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.3rem; }
  .product-brand { color: #999; font-size: 0.75rem; }
  .product-origin { background: #f0f0f0; color: #666; padding: 0.1rem 0.4rem; border-radius: 3px; font-size: 0.7rem; font-weight: 600; }
  .product-strain { font-size: 0.95rem; font-weight: 700; color: #1a472a; margin-bottom: 0.15rem; line-height: 1.2; }
  .product-name { font-size: 0.72rem; color: #aaa; margin-bottom: 0.5rem; line-height: 1.3; }
  .product-stats { display: flex; gap: 0.4rem; margin-bottom: 0.4rem; }
  .thc, .cbd { font-size: 0.72rem; font-weight: 600; padding: 0.15rem 0.4rem; border-radius: 4px; }
  .thc { background: #e8f5e9; color: #2d6a47; }
  .cbd { background: #e3f2fd; color: #1565c0; }
  .product-effects { display: flex; flex-wrap: wrap; gap: 0.25rem; margin-bottom: 0.75rem; }
  .effect-tag { font-size: 0.68rem; color: #888; background: #f5f5f5; padding: 0.12rem 0.35rem; border-radius: 3px; }
  .product-footer { margin-top: auto; display: flex; align-items: center; justify-content: space-between; padding-top: 0.5rem; border-top: 1px solid #f0f0f0; }
  .product-price strong { font-size: 1.1rem; color: #1a472a; }
  .product-price span { font-size: 0.8rem; color: #999; }
  .btn-add { background: #4caf50; color: white; padding: 0.4rem 0.8rem; border-radius: 6px; font-size: 0.8rem; font-weight: 600; }
  .guide-section { padding: 3rem 1.5rem; background: #f8faf9; }
  .guide-section h2 { font-size: 1.5rem; font-weight: 700; color: #1a472a; margin-bottom: 2rem; text-align: center; }
  .steps-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; }
  .step { text-align: center; padding: 1.5rem; }
  .step-num { width: 48px; height: 48px; background: #e8f5e9; color: #2d6a47; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.25rem; font-weight: 800; margin: 0 auto 1rem; }
  .step h3 { font-size: 1.1rem; font-weight: 700; color: #1a472a; margin-bottom: 0.5rem; }
  .step p { color: #666; font-size: 0.9rem; line-height: 1.6; }
  .faq-section { padding: 3rem 1.5rem; background: white; }
  .faq-section h2 { font-size: 1.5rem; font-weight: 700; color: #1a472a; margin-bottom: 1.5rem; text-align: center; }
  .faq-list { max-width: 800px; margin: 0 auto; }
  .faq-item { background: #f8faf9; border: 1px solid #e8ede9; border-radius: 10px; margin-bottom: 0.75rem; overflow: hidden; }
  .faq-item summary { padding: 1rem 1.25rem; font-weight: 600; color: #1a472a; cursor: pointer; font-size: 0.95rem; }
  .faq-item summary:hover { color: #4caf50; }
  .faq-item p { padding: 0 1.25rem 1rem; color: #555; line-height: 1.6; font-size: 0.9rem; }
  .cta-section { padding: 3rem 1.5rem; background: white; }
  .cta-box { background: linear-gradient(135deg, #1b3a4b, #274c5e, #3a6b7e); border-radius: 16px; padding: 3rem; text-align: center; color: white; }
  .cta-box h2 { font-size: 1.75rem; font-weight: 800; margin-bottom: 0.5rem; }
  .cta-box p { color: rgba(255,255,255,0.75); margin-bottom: 1.5rem; }
  .cta-buttons { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
  .btn-primary { background: #4caf50; color: white; padding: 0.8rem 1.75rem; border-radius: 50px; font-weight: 600; transition: all 0.2s; text-decoration: none; }
  .btn-primary:hover { background: #43a047; transform: translateY(-2px); box-shadow: 0 4px 15px rgba(76,175,80,0.4); }
  .btn-lg { padding: 0.9rem 2rem; font-size: 1.05rem; }
  .btn-secondary { background: transparent; color: white; padding: 0.8rem 1.75rem; border-radius: 50px; font-weight: 600; border: 2px solid rgba(255,255,255,0.3); transition: all 0.2s; text-decoration: none; }
  .btn-secondary:hover { border-color: white; background: rgba(255,255,255,0.1); }
  @media (max-width: 968px) {
    .info-grid { grid-template-columns: 1fr; }
    .products-grid { grid-template-columns: repeat(2, 1fr); }
    .compare-grid { grid-template-columns: 1fr; }
    .steps-grid { grid-template-columns: 1fr; }
    .cat-hero h1 { font-size: 2rem; }
  }
  @media (max-width: 576px) {
    .products-grid { grid-template-columns: 1fr; max-width: 380px; margin: 0 auto; }
    .cat-hero h1 { font-size: 1.5rem; }
    .cta-box { padding: 2rem 1.5rem; }
  }
</style>
