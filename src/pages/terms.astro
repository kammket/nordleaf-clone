---
// Terms of Service Page

import Layout from '../layouts/Layout.astro';

const siteUrl = 'https://nordleaf.de';
---

<Layout
  title="Terms of Service - Nordleaf"
  description="Read our terms of service and conditions for using the Nordleaf website."
  canonical={`${siteUrl}/terms`}
>
  <div class="policy-page">
    <section class="page-header">
      <div class="container">
        <h1>Terms of Service</h1>
      </div>
    </section>

    <section class="policy-content">
      <div class="container">
        <h2>Agreement to Terms</h2>
        <p>
          By using this website, you accept and agree to be bound by the terms and
          provision of this agreement.
        </p>

        <h2>License to Use Website</h2>
        <p>
          All intellectual property rights are reserved. You may view and print pages
          from the website for personal use, subject to restrictions set in these terms.
        </p>

        <h2>Limitation of Liability</h2>
        <p>
          The website is provided on an "as is" basis. We make no warranties and disclaim
          liability arising from the use of this website.
        </p>

        <h2>Contact Information</h2>
        <p>Email: <a href="mailto:legal@nordleaf.de">legal@nordleaf.de</a></p>
      </div>
    </section>
  </div>
</Layout>

<style>
  .policy-page {
    min-height: 100vh;
  }

  .container {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  .page-header {
    background: linear-gradient(135deg, #1a472a 0%, #2d6a47 100%);
    color: white;
    padding: 3rem 0;
    text-align: center;
  }

  .page-header h1 {
    color: white;
  }

  .policy-content {
    padding: 3rem 0;
  }

  .policy-content h2 {
    color: #1a472a;
    margin-top: 2rem;
    margin-bottom: 1rem;
  }

  .policy-content p {
    color: #666;
    line-height: 1.8;
  }

  .policy-content a {
    color: #1a472a;
  }
</style>
