---
// Main Layout Component

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  keywords?: string;
  structuredData?: Record<string, unknown>;
}

const {
  title,
  description,
  canonical,
  ogImage,
  keywords,
  structuredData,
} = Astro.props;

import '../styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {keywords && <meta name="keywords" content={keywords} />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {canonical && <link rel="canonical" href={canonical} />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    {
      structuredData && (
        <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
      )
    }
  </head>
  <body>
    <header class="header">
      <div class="container">
        <nav>
          <a href="/" class="logo">Nordleaf</a>
          <ul class="nav-links">
            <li><a href="/">Home</a></li>
            <li><a href="/products">Products</a></li>
            <li><a href="/blog">Blog</a></li>
            <li><a href="/about">About</a></li>
            <li><a href="/contact">Contact</a></li>
          </ul>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="footer">
      <div class="container">
        <div class="footer-content">
          <div>
            <h3>About Nordleaf</h3>
            <p>Premium organic and sustainable products for conscious consumers.</p>
          </div>
          <div>
            <h3>Links</h3>
            <ul>
              <li><a href="/privacy">Privacy Policy</a></li>
              <li><a href="/terms">Terms of Service</a></li>
              <li><a href="/faq">FAQ</a></li>
              <li><a href="/sitemap.xml">Sitemap</a></li>
            </ul>
          </div>
          <div>
            <h3>Contact</h3>
            <p>Email: <a href="mailto:info@nordleaf.de">info@nordleaf.de</a></p>
            <p>Phone: <a href="tel:+49123456789">+49 123 456789</a></p>
          </div>
        </div>
        <div class="footer-bottom">
          <p>&copy; 2024 Nordleaf. All rights reserved.</p>
        </div>
      </div>
    </footer>
  </body>
</html>

<style>
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  .header {
    background: #1a472a;
    color: white;
    padding: 1rem 0;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  .header nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    font-size: 1.5rem;
    font-weight: 700;
    color: white;
  }

  .nav-links {
    display: flex;
    list-style: none;
    gap: 2rem;
  }

  .nav-links a {
    color: white;
    transition: color 0.3s;
  }

  .nav-links a:hover {
    color: #4caf50;
  }

  .footer {
    background: #1a472a;
    color: white;
    padding: 3rem 0 1rem;
    margin-top: 4rem;
  }

  .footer-content {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
    margin-bottom: 2rem;
  }

  .footer-content h3 {
    color: #4caf50;
    margin-bottom: 1rem;
  }

  .footer-content a {
    color: rgba(255, 255, 255, 0.9);
  }

  .footer-content ul {
    list-style: none;
  }

  .footer-content li {
    margin-bottom: 0.5rem;
  }

  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding-top: 1rem;
    text-align: center;
    color: rgba(255, 255, 255, 0.8);
  }

  @media (max-width: 768px) {
    .nav-links {
      gap: 1rem;
      font-size: 0.9rem;
    }
  }

  @media (max-width: 480px) {
    .header nav {
      flex-direction: column;
      gap: 1rem;
    }

    .nav-links {
      flex-direction: column;
      gap: 0.5rem;
    }
  }
</style>
